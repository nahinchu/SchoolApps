<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SchoolApp – Nền tảng quản lý học tập hiện đại" />
    <title>@ViewData["Title"] - SchoolApp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link href="~/css/Schoolapp.css" rel="stylesheet" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    @if (Context.Session.GetString("Role") == "Admin")
    {
        <div class="sa-admin-bar">
            <i class="bi bi-shield-fill-check"></i>
            Bạn đang đăng nhập với quyền <strong>Quản trị viên</strong>
        </div>
    }
    <header class="sa-header" id="sa-header">
        <div class="container">
            <a class="sa-brand" asp-controller="Home" asp-action="Index" aria-label="SchoolApp - Trang chủ">
                <div class="sa-brand-icon">🎓</div>
                <span class="sa-brand-name">School<span>App</span></span>
            </a>

            <button class="sa-toggler" id="sa-toggler" aria-label="Mở menu" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <div class="sa-nav-container" id="sa-nav-container">
                <ul class="sa-nav" role="navigation" aria-label="Điều hướng chính">
                    <li>
                        <a class="sa-nav-link" asp-controller="Course" asp-action="Index">
                            <i class="bi bi-book nav-icon"></i>
                            Khóa học
                        </a>
                    </li>
                    @if (Context.Session.GetString("Role") == "Admin")
                    {
                        <li>
                            <a class="sa-nav-link" asp-controller="Student" asp-action="Index">
                                <i class="bi bi-people nav-icon"></i>
                                Học viên
                            </a>
                        </li>
                        <li>
                            <a class="sa-nav-link" asp-controller="Enrollment" asp-action="Index">
                                <i class="bi bi-journal-check nav-icon"></i>
                                Đăng ký học
                            </a>
                        </li>
                        <li>
                            <a class="sa-nav-link" asp-controller="QuestionBank" asp-action="Index">
                                <i class="bi bi-bank nav-icon"></i>
                                Ngân hàng câu hỏi
                            </a>
                        </li>
                    }

                    @if (Context.Session.GetString("Role") == "Student")
                    {
                        <li>
                            <a class="sa-nav-link" asp-controller="Enrollment" asp-action="MyEnrollments">
                                <i class="bi bi-mortarboard nav-icon"></i>
                                Khóa học của tôi
                            </a>
                        </li>
                    }
                </ul>

                <ul class="sa-user-section" aria-label="Tài khoản">
                    @if (Context.Session.GetString("StudentName") != null)
                    {
                        var studentName = Context.Session.GetString("StudentName");
                        var role = Context.Session.GetString("Role");
                        var initials = studentName?.Length > 0 ? studentName[0].ToString().ToUpper() : "U";
                        <li class="dropdown">
                            <button type="button" class="sa-greeting dropdown-toggle"
                                    data-bs-toggle="dropdown" data-bs-offset="0,10"
                                    aria-expanded="false">
                                <div class="sa-greeting-avatar">@initials</div>
                                <span class="sa-greeting-name">@studentName</span>
                                @if (role == "Admin")
                                {
                                    <span class="sa-badge-admin"><i class="bi bi-shield-fill-check"></i> Admin</span>
                                }
                                else if (role == "Student")
                                {
                                    <span class="sa-badge-student"><i class="bi bi-mortarboard-fill"></i> Học viên</span>
                                }
                                <i class="bi bi-chevron-down sa-greeting-chevron"></i>
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end sa-user-dropdown-menu"
                                style="
                                        background-color: #1b2d42;
                                        border: 1px solid rgba(201,168,76,0.25);
                                        border-radius: 12px;
                                        box-shadow: 0 16px 40px rgba(0,0,0,0.5);
                                        padding: 6px;
                                        min-width: 220px;
                                    ">
                                <!-- Header -->
                                <li style="
                                        display: flex;
                                        align-items: center;
                                        gap: 12px;
                                        padding: 10px 12px 8px;
                                    ">
                                    <div style="
                                            width:42px; height:42px; flex-shrink:0;
                                            background: linear-gradient(135deg, #c9a84c, #e8c96e);
                                            border-radius: 50%;
                                            display:flex; align-items:center; justify-content:center;
                                            font-size:16px; font-weight:700; color:#0d1b2a;
                                            box-shadow: 0 0 0 3px rgba(201,168,76,0.25);
                                        ">
                                        @initials
                                    </div>
                                    <div>
                                        <div style="font-weight:600; font-size:.9rem; color:#ffffff; line-height:1.3;">@studentName</div>
                                        <div style="font-size:.75rem; color:#c9a84c; margin-top:2px;">
                                            @if (role == "Admin")
                                            {
                                                <text><i class="bi bi-shield-fill-check"></i> Quản trị viên</text>
                                            }
                                            else
                                            {
                                                <text><i class="bi bi-mortarboard-fill"></i> Học viên</text>
                                            }
                                        </div>
                                    </div>
                                </li>

                                <li><hr style="border-color: rgba(201,168,76,0.2); margin: 4px 0; opacity:1;"></li>

                                <li>
                                    <a class="sa-dditem" asp-controller="Account" asp-action="EditProfile"
                                       style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:6px;border-left:2px solid transparent;color:rgba(201,168,76,0.9);font-size:.875rem;font-weight:500;text-decoration:none;">
                                        <span style="width:26px;height:26px;display:flex;align-items:center;justify-content:center;border-radius:6px;background:rgba(201,168,76,0.12);font-size:.85rem;flex-shrink:0;">
                                            <i class="bi bi-person-gear"></i>
                                        </span>
                                        Sửa profile
                                    </a>
                                </li>

                                <li><hr style="border-color: rgba(201,168,76,0.2); margin: 4px 0; opacity:1;"></li>

                                <li>
                                    <a class="sa-dditem sa-dditem--danger" asp-controller="Account" asp-action="Logout"
                                       style="display:flex;align-items:center;gap:10px;padding:9px 12px;border-radius:6px;border-left:2px solid transparent;color:rgba(224,112,112,0.85);font-size:.875rem;font-weight:500;text-decoration:none;">
                                        <span style="width:26px;height:26px;display:flex;align-items:center;justify-content:center;border-radius:6px;background:rgba(192,57,43,0.15);font-size:.85rem;flex-shrink:0;">
                                            <i class="bi bi-box-arrow-right"></i>
                                        </span>
                                        Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li>
                            <a class="sa-btn-login" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-person-fill"></i>
                                Đăng nhập
                            </a>
                        </li>
                        <li>
                            <a class="sa-btn-register" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus"></i>
                                Đăng ký
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>

    </header>

    <main class="sa-main" id="sa-main" role="main">
        <div class="container">
            @if (TempData["Success"] != null)
            {
                <div class="sa-alert sa-alert-success" role="alert" id="alert-success">
                    <span class="sa-alert-icon"><i class="bi bi-check-circle-fill"></i></span>
                    <span>@TempData["Success"]</span>
                    <button class="sa-alert-close" onclick="dismissAlert('alert-success')" aria-label="Đóng">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="sa-alert sa-alert-danger" role="alert" id="alert-error">
                    <span class="sa-alert-icon"><i class="bi bi-exclamation-circle-fill"></i></span>
                    <span>@TempData["Error"]</span>
                    <button class="sa-alert-close" onclick="dismissAlert('alert-error')" aria-label="Đóng">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
            }

            @RenderBody()
        </div>
    </main>
    <footer class="sa-footer" role="contentinfo">

        <div class="sa-footer-top">
            <div class="container">
                <div class="sa-footer-grid">

                    @* Cot 1: Brand *@
                    <div>
                        <a class="sa-footer-brand" asp-controller="Home" asp-action="Index">
                            <div class="sa-brand-icon" style="width:34px;height:34px;font-size:16px;">&#127891;</div>
                            <span class="sa-footer-brand-name">School<span>App</span></span>
                        </a>
                        <p class="sa-footer-desc">
                            Nền tảng quản lý học tập hiện đại, kết nối học viên và giáo viên
                            trong một không gian học thuật chuyên nghiệp.
                        </p>
                    </div>

                    @* Cot 2: Kham pha — hien thi theo role *@
                    <div>
                        <p class="sa-footer-heading">
                            @if (Context.Session.GetString("Role") == "Admin")
                            {
                                <text>Quản trị</text>
                            }
                            else
                            {
                                <text>Khám phá</text>
                            }
                        </p>
                        <ul class="sa-footer-links">
                            <li><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                            <li><a asp-controller="Course" asp-action="Index">Khóa học</a></li>
                            @if (Context.Session.GetString("Role") == "Admin")
                            {
                                <li><a asp-controller="Student" asp-action="Index">Quản lý học viên</a></li>
                                <li><a asp-controller="Enrollment" asp-action="Index">Quản lý đăng ký</a></li>
                                <li><a asp-controller="QuestionBank" asp-action="Index">Ngân hàng câu hỏi</a></li>
                            }
                            @if (Context.Session.GetString("Role") == "Student")
                            {
                                <li><a asp-controller="Enrollment" asp-action="MyEnrollments">Khóa học của tôi</a></li>
                            }
                        </ul>
                    </div>

                    @* Cot 3: Tai khoan — hien thi theo role *@
                    <div>
                        <p class="sa-footer-heading">Tài khoản</p>
                        <ul class="sa-footer-links">
                            @{
                                var footerRole = Context.Session.GetString("Role");
                            }
                            @if (footerRole == null)
                            {
                                <li><a asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                                <li><a asp-controller="Account" asp-action="Register">Đăng ký tài khoản</a></li>
                            }
                            else if (footerRole == "Admin")
                            {
                                <li><a asp-controller="Student" asp-action="Create">Thêm học viên mới</a></li>
                                <li><a asp-controller="Course" asp-action="Index">Quản lý khóa học</a></li>
                                <li><a asp-controller="Account" asp-action="Logout">Đăng xuất</a></li>
                            }
                            else
                            {
                                <li><a asp-controller="Enrollment" asp-action="MyEnrollments">Khóa học của tôi</a></li>
                                <li><a asp-controller="Account" asp-action="EditProfile">Sửa profile</a></li>
                                <li><a asp-controller="Account" asp-action="Logout">Đăng xuất</a></li>
                            }
                        </ul>
                    </div>

                    @* Cot 4: Lien he *@
                    <div>
                        <p class="sa-footer-heading">Liên hệ</p>
                        <ul class="sa-footer-links">
                            <li>
                                <a href="mailto:support@schoolapp.vn">
                                    <i class="bi bi-envelope"></i> support@schoolapp.vn
                                </a>
                            </li>
                            <li>
                                <a href="tel:+842812345678">
                                    <i class="bi bi-telephone"></i> 028 1234 5678
                                </a>
                            </li>
                            <li>
                                <a href="#">
                                    <i class="bi bi-geo-alt"></i> TP.Đà Nẵng, Việt Nam
                                </a>
                            </li>
                        </ul>
                    </div>

                </div>
            </div>
        </div>

        <div class="sa-footer-divider"></div>

        <div class="container">
            <div class="sa-footer-bottom">
                <p class="sa-footer-copy">
                    &copy; 2026 <strong>SchoolApp</strong>. Bảo lưu mọi quyền.
                </p>
                <p class="sa-footer-tagline">Kiến thức là hành trình, không phải đích đến.</p>
            </div>
        </div>

    </footer>
    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function dismissAlert(id) {
            var el = document.getElementById(id);
            if (el) el.remove();
        }

        document.getElementById('sa-toggler').addEventListener('click', function () {
            var container = document.getElementById('sa-nav-container');
            var open = container.classList.toggle('open');
            this.classList.toggle('open', open);
            this.setAttribute('aria-expanded', open);
        });


        // Chevron xoay khi dropdown mở/đóng
        document.querySelectorAll('.sa-greeting.dropdown-toggle').forEach(function(btn) {
            btn.addEventListener('shown.bs.dropdown', function() {
                var chevron = btn.querySelector('.sa-greeting-chevron');
                if (chevron) chevron.style.transform = 'rotate(180deg)';
            });
            btn.addEventListener('hidden.bs.dropdown', function() {
                var chevron = btn.querySelector('.sa-greeting-chevron');
                if (chevron) chevron.style.transform = '';
            });
        });

        // Fix: xóa backdrop giả do extension inject
        var backdropInterval;
        $(document).on('show.bs.modal', '.modal', function () {
            backdropInterval = setInterval(function () {
                var backdrops = document.querySelectorAll('.modal-backdrop');
                if (backdrops.length > 1) {
                    for (var i = 1; i < backdrops.length; i++) {
                        backdrops[i].remove();
                    }
                }
            }, 100);
        });
        $(document).on('hidden.bs.modal', '.modal', function () {
            clearInterval(backdropInterval);
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>