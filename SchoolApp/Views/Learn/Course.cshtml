@using SchoolApp.Models
@using SchoolApp.Models.Enums
@model Course

@{
    ViewData["Title"] = "Học - " + Model.CourseName;
    var currentLesson = ViewData["CurrentLesson"] as Lesson;
    var progressMap = (ViewData["ProgressMap"] as Dictionary<int, LessonProgress>) ?? new();
    var prevLesson = ViewData["PrevLesson"] as Lesson;
    var nextLesson = ViewData["NextLesson"] as Lesson;
    var totalLessons = (int)(ViewData["TotalLessons"] ?? 0);
    var completedCount = (int)(ViewData["CompletedCount"] ?? 0);
    var pctComplete = totalLessons > 0 ? completedCount * 100 / totalLessons : 0;

    string GetEmbedUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return "";
        if (url.Contains("youtube.com/watch", StringComparison.OrdinalIgnoreCase))
        {
            var idPart = url.Split("v=").Last().Split("&").First();
            return $"https://www.youtube.com/embed/{idPart}";
        }
        if (url.Contains("youtu.be/", StringComparison.OrdinalIgnoreCase))
        {
            var idPart = url.Split("youtu.be/").Last().Split("?").First();
            return $"https://www.youtube.com/embed/{idPart}";
        }
        if (url.Contains("vimeo.com/", StringComparison.OrdinalIgnoreCase) && !url.Contains("player.vimeo.com"))
        {
            var idPart = url.Split("vimeo.com/").Last().Split("?").First();
            return $"https://player.vimeo.com/video/{idPart}";
        }
        return url;
    }
}

<style>
    .learn-wrap {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 1.5rem;
        align-items: start;
    }

    @@media (max-width: 991px) {
        .learn-wrap {
            grid-template-columns: 1fr;
        }
    }

    /* ========= HEADER ========= */
    .learn-header {
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
        color: var(--white);
        padding: 1.5rem;
        border-radius: var(--radius-md);
        margin-bottom: 1.5rem;
    }

        .learn-header h1 {
            font-family: var(--font-display);
            font-size: 1.5rem;
            margin: 0 0 .5rem;
            color: var(--gold-light);
        }

    .learn-progress-bar {
        height: 10px;
        background: rgba(255,255,255,.15);
        border-radius: 999px;
        overflow: hidden;
        margin-top: .75rem;
    }

        .learn-progress-bar > div {
            height: 100%;
            background: linear-gradient(90deg, var(--gold), var(--gold-light));
            transition: width .4s ease;
        }

    .learn-progress-text {
        font-size: .85rem;
        color: rgba(255,255,255,.85);
        margin-top: .35rem;
    }

    /* ========= SIDEBAR ========= */
    .learn-sidebar {
        background: var(--white);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        position: sticky;
        top: 1rem;
        max-height: calc(100vh - 2rem);
        overflow-y: auto;
    }

    .module-block {
        border-bottom: 1px solid var(--smoke);
    }

        .module-block:last-child {
            border-bottom: none;
        }

    .module-header {
        padding: .85rem 1rem;
        background: var(--off-white);
        font-weight: 700;
        color: var(--navy);
        font-size: .92rem;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-left: 4px solid var(--navy);
    }

        .module-header:hover {
            background: var(--smoke);
        }

    .lesson-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    /* ===== LESSON ITEM ===== */
    .lesson-row {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .75rem 1rem .75rem 1.5rem;
        color: var(--text-mid);
        text-decoration: none;
        font-size: .9rem;
        border-left: 4px solid transparent;
        transition: all .15s ease;
        background: var(--white);
    }

        .lesson-row:hover {
            background: var(--off-white);
            color: var(--navy);
        }

        .lesson-row.active {
            background: linear-gradient(90deg, rgba(20,33,61,.08) 0%, transparent 100%);
            color: var(--navy);
            border-left-color: var(--navy);
            font-weight: 600;
        }

    .lesson-icon {
        width: 24px;
        height: 24px;
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-size: .9rem;
    }

        .lesson-icon.done {
            background: var(--success);
            color: var(--white);
        }

        .lesson-icon.current {
            background: var(--navy);
            color: var(--gold-light);
        }

        .lesson-icon.todo {
            background: var(--smoke);
            color: var(--text-light);
            border: 1.5px solid var(--text-light);
        }

    .lesson-row .lesson-title {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .lesson-meta {
        font-size: .72rem;
        color: var(--text-light);
        flex-shrink: 0;
    }

    /* ===== QUIZ CARD (NỔI BẬT) ===== */
    .quiz-card {
        margin: .5rem .75rem .75rem 2.5rem;
        padding: .75rem .9rem;
        background: linear-gradient(135deg, #fff8e1 0%, #fff3cd 100%);
        border: 2px dashed var(--gold);
        border-radius: var(--radius-sm);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: .7rem;
        transition: all .2s ease;
        position: relative;
    }

        .quiz-card::before {
            content: "QUIZ";
            position: absolute;
            top: -9px;
            left: 12px;
            background: var(--gold);
            color: var(--navy);
            font-size: .65rem;
            font-weight: 800;
            padding: 2px 8px;
            border-radius: 999px;
            letter-spacing: .08em;
        }

        .quiz-card:hover {
            background: linear-gradient(135deg, #fff3cd 0%, #ffe69c 100%);
            transform: translateX(2px);
            box-shadow: 0 4px 8px rgba(212,175,55,.25);
        }

        .quiz-card .quiz-icon-circle {
            width: 32px;
            height: 32px;
            flex-shrink: 0;
            background: var(--gold);
            color: var(--navy);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
        }

        .quiz-card .quiz-text {
            flex: 1;
        }

        .quiz-card .quiz-text-title {
            font-weight: 700;
            color: var(--navy);
            font-size: .85rem;
            line-height: 1.2;
        }

        .quiz-card .quiz-text-sub {
            font-size: .72rem;
            color: var(--text-mid);
            margin-top: 2px;
        }

        .quiz-card .quiz-arrow {
            color: var(--navy);
            font-size: 1rem;
        }

    /* ========= MAIN ========= */
    .learn-main {
        background: var(--white);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    .lesson-title-bar {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--smoke);
    }

        .lesson-title-bar h2 {
            font-family: var(--font-display);
            font-size: 1.3rem;
            color: var(--navy);
            margin: 0 0 .25rem;
        }

    .lesson-meta-row {
        font-size: .82rem;
        color: var(--text-light);
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .lesson-body {
        padding: 1.5rem;
    }

    .video-frame {
        position: relative;
        padding-top: 56.25%;
        background: #000;
        border-radius: var(--radius-sm);
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

        .video-frame iframe, .video-frame video {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            border: 0;
        }

    .article-content {
        line-height: 1.7;
        color: var(--text-dark, #222);
        font-size: 1rem;
    }

        .article-content :is(h1,h2,h3,h4) {
            color: var(--navy);
            margin-top: 1.5rem;
        }

        .article-content img {
            max-width: 100%;
            height: auto;
            border-radius: var(--radius-sm);
        }

    /* Quiz banner trong main content */
    .quiz-banner {
        margin-top: 2rem;
        background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
        color: var(--white);
        border-radius: var(--radius-md);
        padding: 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
        position: relative;
        overflow: hidden;
        border-left: 6px solid var(--gold);
    }

        .quiz-banner::after {
            content: "📋";
            position: absolute;
            right: -10px;
            bottom: -20px;
            font-size: 8rem;
            opacity: .07;
            pointer-events: none;
        }

    .quiz-banner-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: var(--gold);
        color: var(--navy);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        flex-shrink: 0;
    }

    .quiz-banner-text {
        flex: 1;
        min-width: 200px;
        position: relative;
        z-index: 1;
    }

    .quiz-banner-label {
        display: inline-block;
        background: var(--gold);
        color: var(--navy);
        font-size: .7rem;
        font-weight: 800;
        padding: 2px 10px;
        border-radius: 999px;
        letter-spacing: .1em;
        margin-bottom: .35rem;
    }

    .quiz-banner-title {
        font-family: var(--font-display);
        font-size: 1.2rem;
        color: var(--gold-light);
        margin: 0;
    }

    .quiz-banner-sub {
        font-size: .85rem;
        color: rgba(255,255,255,.7);
        margin-top: .25rem;
    }

    .lesson-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid var(--smoke);
        background: var(--off-white);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .empty-state {
        text-align: center;
        padding: 3rem 1.5rem;
        color: var(--text-light);
    }
</style>

<div class="learn-header">
    <div style="display:flex; justify-content:space-between; align-items:start; gap:1rem; flex-wrap:wrap;">
        <div style="flex:1; min-width:240px;">
            <h1>📚 @Model.CourseName</h1>
            <div style="font-size:.88rem; color:rgba(255,255,255,.65);">
                @Model.Modules.Count chương · @totalLessons bài học
            </div>
        </div>
        <a asp-controller="Enrollment" asp-action="MyEnrollments"
           class="sa-btn sa-btn-outline" style="border-color:var(--gold-light); color:var(--gold-light);">
            ← Khoá của tôi
        </a>
    </div>
    <div class="learn-progress-bar"><div style="width:@(pctComplete)%;"></div></div>
    <div class="learn-progress-text">
        Tiến độ: <strong>@completedCount / @totalLessons</strong> bài đã hoàn thành (@pctComplete%)
    </div>
</div>

<div class="learn-wrap">

    <!-- ============ SIDEBAR ============ -->
    <aside class="learn-sidebar">
        @if (!Model.Modules.Any())
        {
            <div class="empty-state">
                <i class="bi bi-folder-x" style="font-size:2rem;"></i>
                <p>Khoá học chưa có nội dung</p>
            </div>
        }
        @foreach (var m in Model.Modules)
        {
            <div class="module-block">
                <div class="module-header" onclick="$(this).next('.lesson-list').slideToggle(150);">
                    <span><i class="bi bi-collection"></i> @m.Title</span>
                    <small class="text-muted">@m.Lessons.Count bài</small>
                </div>
                <ul class="lesson-list">
                    @foreach (var l in m.Lessons)
                    {
                        var p = progressMap.TryGetValue(l.LessonId, out var pv) ? pv : null;
                        var isDone = p != null && p.Status == ProgressStatus.Completed;
                        var isCurrent = currentLesson != null && currentLesson.LessonId == l.LessonId;
                        var iconClass = isDone ? "done" : (isCurrent ? "current" : "todo");
                        var iconChar = isDone ? "bi-check-lg"
                        : (isCurrent ? "bi-play-fill" : "bi-circle");

                        <li>
                            <a class="lesson-row @(isCurrent ? "active" : "")"
                               asp-action="Course" asp-route-id="@Model.CourseId" asp-route-lessonId="@l.LessonId">
                                <span class="lesson-icon @iconClass"><i class="bi @iconChar"></i></span>
                                <span class="lesson-title">@l.Title</span>
                                @if (l.DurationMinutes > 0)
                                {
                                    <span class="lesson-meta">@l.DurationMinutes'</span>
                                }
                            </a>

                            @if (l.Quiz != null && l.Quiz.IsPublished)
                            {
                                <a class="quiz-card" asp-controller="Quiz" asp-action="Take" asp-route-id="@l.Quiz.QuizId">
                                    <span class="quiz-icon-circle"><i class="bi bi-pencil-square"></i></span>
                                    <div class="quiz-text">
                                        <div class="quiz-text-title">@l.Quiz.Title</div>
                                        <div class="quiz-text-sub">
                                            @l.Quiz.Questions.Count câu hỏi · Đạt @l.Quiz.PassingScore%
                                        </div>
                                    </div>
                                    <i class="bi bi-arrow-right-circle-fill quiz-arrow"></i>
                                </a>
                            }
                        </li>
                    }
                    @if (!m.Lessons.Any())
                    {
                        <li style="padding:.65rem 1rem .65rem 1.5rem; color:var(--text-light); font-size:.85rem; font-style:italic;">
                            Chương này chưa có bài học
                        </li>
                    }
                </ul>
            </div>
        }
    </aside>

    <!-- ============ MAIN CONTENT ============ -->
    <main class="learn-main">
        @if (currentLesson == null)
        {
            <div class="empty-state">
                <i class="bi bi-journal-x" style="font-size:3rem;"></i>
                <h4 class="mt-3">Khoá học chưa có bài học nào để học</h4>
                <p>Vui lòng quay lại sau khi giảng viên cập nhật nội dung.</p>
            </div>
        }
        else
        {
            var curProgress = progressMap.TryGetValue(currentLesson.LessonId, out var cp) ? cp : null;
            var isCompleted = curProgress != null && curProgress.Status == ProgressStatus.Completed;

            <div class="lesson-title-bar">
                <div style="display:inline-block; background:var(--navy); color:var(--gold-light); font-size:.7rem; font-weight:700; padding:3px 10px; border-radius:999px; letter-spacing:.1em; margin-bottom:.5rem;">
                    BÀI HỌC
                </div>
                <h2>@currentLesson.Title</h2>
                <div class="lesson-meta-row">
                    @switch (currentLesson.Type)
                    {
                        case LessonType.Video:
                            <span><i class="bi bi-play-btn"></i> Video</span>
                            break;
                        case LessonType.Text:

                            <span><i class="bi bi-file-text"></i> Bài viết</span>
                            break;
                        case LessonType.Mixed:

                            <span><i class="bi bi-collection-play"></i> Video + Bài viết</span>
                            break;
                    }
                    @if (currentLesson.DurationMinutes > 0)
                    {
                        <span><i class="bi bi-clock"></i> @currentLesson.DurationMinutes phút</span>
                    }
                    @if (isCompleted)
                    {
                        <span style="color:var(--success);"><i class="bi bi-check-circle-fill"></i> Đã hoàn thành</span>
                    }
                    else
                    {
                        <span style="color:var(--gold);"><i class="bi bi-hourglass-split"></i> Đang học</span>
                    }
                </div>
            </div>

            <div class="lesson-body">
                @if ((currentLesson.Type == LessonType.Video || currentLesson.Type == LessonType.Mixed)
                            && !string.IsNullOrWhiteSpace(currentLesson.VideoUrl))
                {
                    var embed = GetEmbedUrl(currentLesson.VideoUrl);
                    <div class="video-frame">
                        <iframe src="@embed"
                                allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen></iframe>
                    </div>
                }

                @if ((currentLesson.Type == LessonType.Text || currentLesson.Type == LessonType.Mixed)
                            && !string.IsNullOrWhiteSpace(currentLesson.HtmlContent))
                {
                    <div class="article-content">@Html.Raw(currentLesson.HtmlContent)</div>
                }

                @if (string.IsNullOrWhiteSpace(currentLesson.VideoUrl)
                            && string.IsNullOrWhiteSpace(currentLesson.HtmlContent))
                {
                    <div class="empty-state">
                        <i class="bi bi-info-circle" style="font-size:2rem;"></i>
                        <p>Bài học này chưa có nội dung</p>
                    </div>
                }

                @if (currentLesson.Quiz != null && currentLesson.Quiz.IsPublished)
                {
                    <div class="quiz-banner">
                        <div class="quiz-banner-icon">
                            <i class="bi bi-pencil-square"></i>
                        </div>
                        <div class="quiz-banner-text">
                            <span class="quiz-banner-label">📋 BÀI KIỂM TRA</span>
                            <h3 class="quiz-banner-title">@currentLesson.Quiz.Title</h3>
                            <div class="quiz-banner-sub">
                                @currentLesson.Quiz.Questions.Count câu hỏi
                                @if (currentLesson.Quiz.TimeLimitMinutes > 0)
                                {
                                    <text> · ⏱ @currentLesson.Quiz.TimeLimitMinutes phút</text>
                                }
                                <text> · 🎯 Điểm đạt @currentLesson.Quiz.PassingScore%</text>
                            </div>
                        </div>
                        <a asp-controller="Quiz" asp-action="Take" asp-route-id="@currentLesson.Quiz.QuizId"
                           class="sa-btn sa-btn-gold" style="font-weight:700;">
                            <i class="bi bi-play-fill"></i> Bắt đầu làm bài
                        </a>
                    </div>
                }
            </div>

            <div class="lesson-footer">
                <div>
                    @if (prevLesson != null)
                    {
                        <a asp-action="Course" asp-route-id="@Model.CourseId" asp-route-lessonId="@prevLesson.LessonId"
                           class="sa-btn sa-btn-outline">
                            <i class="bi bi-arrow-left"></i> Bài trước
                        </a>
                    }
                </div>

                <div style="display:flex; gap:.5rem;">
                    @if (!isCompleted)
                    {
                        <button id="btnMarkComplete" class="sa-btn sa-btn-primary"
                                data-lesson-id="@currentLesson.LessonId">
                            <i class="bi bi-check-lg"></i> Đánh dấu hoàn thành
                        </button>
                    }
                    else
                    {
                        <span class="sa-btn sa-btn-outline" style="color:var(--success); border-color:var(--success); cursor:default;">
                            <i class="bi bi-check-circle-fill"></i> Đã hoàn thành
                        </span>
                    }
                </div>

                <div>
                    @if (nextLesson != null)
                    {
                        <a asp-action="Course" asp-route-id="@Model.CourseId" asp-route-lessonId="@nextLesson.LessonId"
                           class="sa-btn sa-btn-gold">
                            Bài tiếp theo <i class="bi bi-arrow-right"></i>
                        </a>
                    }
                </div>
            </div>
        }
    </main>
</div>

@section Scripts {
    <form id="antiForgeryForm">@Html.AntiForgeryToken()</form>

    <script>
        function showToast(message, type = 'success') {
            const cls  = type === 'success' ? 'sa-alert-success' : 'sa-alert-danger';
            const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-circle-fill';
            const t = $(`<div class="sa-alert ${cls}" style="position:fixed;top:1rem;right:1rem;z-index:9999;min-width:300px;">
                <span class="sa-alert-icon"><i class="bi ${icon}"></i></span>
                <span>${message}</span>
                <button class="sa-alert-close" onclick="$(this).parent().remove()"><i class="bi bi-x"></i></button>
            </div>`);
            $('body').append(t);
            setTimeout(() => t.fadeOut(400, () => t.remove()), 2500);
        }

        $('#btnMarkComplete').on('click', function () {
            const $btn = $(this);
            const lessonId = $btn.data('lesson-id');
            const token = $('#antiForgeryForm input[name="__RequestVerificationToken"]').val();

            $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Đang xử lý...');

            $.ajax({
                url: '@Url.Action("MarkComplete", "Learn")',
                type: 'POST',
                data: { lessonId: lessonId, __RequestVerificationToken: token },
                success: function (res) {
                    if (res.success) {
                        showToast(res.message, 'success');
                        setTimeout(() => location.reload(), 600);
                    } else {
                        showToast(res.message || 'Lỗi xảy ra', 'danger');
                        $btn.prop('disabled', false).html('<i class="bi bi-check-lg"></i> Đánh dấu hoàn thành');
                    }
                },
                error: function () {
                    showToast('Lỗi kết nối!', 'danger');
                    $btn.prop('disabled', false).html('<i class="bi bi-check-lg"></i> Đánh dấu hoàn thành');
                }
            });
        });
    </script>
}
