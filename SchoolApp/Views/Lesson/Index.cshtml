@using X.PagedList
@model IPagedList<SchoolApp.Models.Lesson>

@{
    ViewData["Title"] = "Quản lý Bài học";
    var moduleId = ViewData["ModuleId"] != null ? (int)ViewData["ModuleId"] : 0;
    var moduleName = ViewData["ModuleName"] as string ?? "Chương học";
    var courseId = ViewData["CourseId"] != null ? (int)ViewData["CourseId"] : 0;
}

<div class="sa-page-hero">
    <h1>📝 Bài học - @moduleName</h1>
    <p>Quản lý nội dung bài học trong chương</p>
</div>

<div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; margin-bottom:1.5rem; flex-wrap:wrap;">
    <form id="searchForm" method="get" style="flex:1; max-width:400px; display:flex; gap:0;">
        <input type="hidden" name="moduleId" value="@moduleId" />
        <div style="position:relative; flex:1;">
            <i class="bi bi-search" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-light);"></i>
            <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]"
                   class="sa-input" placeholder="Tìm bài học..."
                   style="padding-left:36px; border-radius:var(--radius-sm) 0 0 var(--radius-sm);" />
        </div>
        <button type="submit" class="sa-btn sa-btn-primary" style="border-radius:0 var(--radius-sm) var(--radius-sm) 0;">Tìm</button>
    </form>

    <button type="button" class="sa-btn sa-btn-gold" data-bs-toggle="modal" data-bs-target="#lessonModal"
            onclick="openCreateModal()">
        <i class="bi bi-plus-circle"></i> Thêm bài học mới
    </button>
</div>

<div id="lessonTableContainer">
    @{
        ViewData["ModuleId"] = moduleId;
    }
    @await Html.PartialAsync("_LessonTable", Model)
</div>

<!-- ==================== MODAL ==================== -->
<div class="modal fade" id="lessonModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%); color: var(--gold-light);">
                <h5 id="lessonModalLabel">Thêm bài học mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="modalResult"></div>
                <form id="lessonForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="LessonId" name="LessonId" value="0" />
                    <input type="hidden" id="ModuleId" name="ModuleId" value="@moduleId" />

                    <div class="row">
                        <div class="col-md-8">
                            <label class="sa-label">Tiêu đề <span style="color:red">*</span></label>
                            <input type="text" id="Title" name="Title" class="sa-input" />
                            <div class="invalid-feedback" id="err-Title"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="sa-label">Loại bài học</label>
                            <select id="Type" name="Type" class="sa-input">
                                <option value="0">Video</option>
                                <option value="1">Bài viết</option>
                                <option value="2">Kết hợp</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <label class="sa-label">URL Video</label>
                            <input type="url" id="VideoUrl" name="VideoUrl" class="sa-input" placeholder="https://..." />
                        </div>
                        <div class="col-md-3">
                            <label class="sa-label">Thời lượng (phút)</label>
                            <input type="number" id="DurationMinutes" name="DurationMinutes" class="sa-input" min="0" value="0" />
                        </div>
                        <div class="col-md-3">
                            <label class="sa-label">Thứ tự</label>
                            <input type="number" id="OrderIndex" name="OrderIndex" class="sa-input" min="0" value="0" />
                        </div>
                    </div>

                    <div class="sa-form-group mt-3">
                        <label class="sa-label">Nội dung bài viết (HTML)</label>
                        <textarea id="HtmlContent" name="HtmlContent" class="sa-input" rows="6"></textarea>
                    </div>

                    <div class="form-check form-switch mt-3">
                        <input type="checkbox" id="IsPublished" name="IsPublished" value="true" class="form-check-input" checked />
                        <label class="form-check-label">Công bố bài học (Học viên có thể xem)</label>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="sa-btn sa-btn-outline" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="sa-btn sa-btn-primary" id="btnSaveLesson">
                    <i class="bi bi-check-lg"></i> <span class="btn-text">Lưu bài học</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <form id="antiForgeryForm">@Html.AntiForgeryToken()</form>

    <script>
        var isEditMode = false;
        var currentModuleId = @moduleId;

        function clearErrors() {
            $('#modalResult').html('');
            $('#lessonForm .sa-input, #lessonForm select').removeClass('is-invalid');
            $('#lessonForm [id^="err-"]').text('');
        }

        function openCreateModal() {
            isEditMode = false;
            $('#lessonModalLabel').text('➕ Thêm bài học mới');
            $('#btnSaveLesson .btn-text').text('Lưu');
            $('#lessonForm')[0].reset();
            $('#LessonId').val(0);
            $('#ModuleId').val(currentModuleId);
            $('#Type').val(0);
            $('#IsPublished').prop('checked', true);
            clearErrors();
            $('#lessonModal').modal('show');
        }

        function openEditModal(id) {
            isEditMode = true;
            $('#lessonModalLabel').text('✏️ Sửa bài học');
            $('#btnSaveLesson .btn-text').text('Cập nhật');
            clearErrors();

            $.get('@Url.Action("GetLesson", "Lesson")/' + id, function (data) {
                $('#LessonId').val(data.lessonId);
                $('#Title').val(data.title);
                $('#Type').val(data.type === 'Video' ? 0 : data.type === 'Text' ? 1 : 2);
                $('#VideoUrl').val(data.videoUrl || '');
                $('#HtmlContent').val(data.htmlContent || '');
                $('#DurationMinutes').val(data.durationMinutes || 0);
                $('#OrderIndex').val(data.orderIndex);
                $('#IsPublished').prop('checked', data.isPublished);
                $('#ModuleId').val(data.moduleId);
                $('#lessonModal').modal('show');
            }).fail(function () {
                showToast('Không thể tải thông tin bài học!', 'danger');
            });
        }

        $(function () {
            $('#btnSaveLesson').on('click', function () {
                clearErrors();
                var url = isEditMode ? '@Url.Action("EditAjax", "Lesson")' : '@Url.Action("CreateAjax", "Lesson")';

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: $('#lessonForm').serialize(),
                    success: function (res) {
                        if (res.success) {
                            $('#lessonModal').modal('hide');
                            showToast(res.message, 'success');
                            loadLessons(1);
                        } else if (res.errors) {
                            $.each(res.errors, function (field, messages) {
                                $('#' + field).addClass('is-invalid');
                                $('#err-' + field).text(messages.join(', '));
                            });
                        }
                    },
                    error: function (xhr) {
                        showToast('Lỗi: ' + (xhr.status === 403 ? 'Không có quyền' : 'Kết nối'), 'danger');
                    }
                });
            });

            $('#searchForm').on('submit', function (e) { e.preventDefault(); loadLessons(1); });

            $(document).on('click', '.ajax-page-link', function (e) {
                e.preventDefault();
                var match = $(this).attr('href').match(/page=(\d+)/);
                loadLessons(match ? parseInt(match[1]) : 1);
            });

            $(document).on('click', '.btn-delete-lesson', function () {
                if (!confirm('Xóa bài học này?')) return;
                var id = $(this).data('id');
                var token = $('#antiForgeryForm input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("Delete", "Lesson")',
                    type: 'POST',
                    data: { id: id, __RequestVerificationToken: token },
                    success: function (res) {
                        if (res.success) {
                            showToast(res.message, 'success');
                            loadLessons(1);
                        } else {
                            showToast(res.message, 'danger');
                        }
                    }
                });
            });

            window.loadLessons = function(page = 1) {
                var searchTerm = $('#searchForm input[name="searchTerm"]').val();
                $.ajax({
                    url: '@Url.Action("Index", "Lesson")',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    data: { moduleId: currentModuleId, searchTerm: searchTerm, page: page },
                    success: function (html) {
                        $('#lessonTableContainer').html(html);
                    }
                });
            };

            window.showToast = function (message, type = 'success') {
                var cls = type === 'success' ? 'sa-alert-success' : 'sa-alert-danger';
                var icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-circle-fill';
                var toast = $(`<div class="sa-alert ${cls}" style="position:fixed;top:1rem;right:1rem;z-index:9999;min-width:320px;">
                    <span class="sa-alert-icon"><i class="bi ${icon}"></i></span>
                    <span>${message}</span>
                    <button class="sa-alert-close" onclick="$(this).parent().remove()"><i class="bi bi-x"></i></button>
                </div>`);
                $('body').append(toast);
                setTimeout(() => toast.fadeOut(400, () => toast.remove()), 3000);
            };
        });
    </script>
}