@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<SchoolApp.Models.Student>
@{
    ViewData["Title"] = "Danh sách học viên";
    var role = Context.Session.GetString("Role");
    var isAdmin = role == "Admin";
}

<!-- ==================== PAGE HERO ==================== -->
<div class="sa-page-hero">
    <h1>🎓 Danh sách học viên</h1>
    <p>Quản lý thông tin và theo dõi học viên</p>
</div>

<!-- ==================== TOOLBAR ==================== -->
<div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; margin-bottom:1.5rem; flex-wrap:wrap;">
    <form id="searchForm" method="get" style="flex:1; max-width:420px; display:flex; gap:0;">
        <div style="position:relative; flex:1;">
            <i class="bi bi-search" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-light); font-size:.85rem;"></i>
            <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]"
                   class="sa-input" placeholder="Tìm theo tên, email, SĐT..."
                   style="padding-left:36px; border-radius:var(--radius-sm) 0 0 var(--radius-sm);" />
        </div>
        <button type="submit" class="sa-btn sa-btn-primary" style="border-radius:0 var(--radius-sm) var(--radius-sm) 0; padding:9px 16px;">
            Tìm
        </button>
    </form>

    @if (isAdmin)
    {
        <button type="button" class="sa-btn sa-btn-gold"
                data-bs-toggle="modal" data-bs-target="#studentModal"
                onclick="openCreateModal()">
            <i class="bi bi-person-plus"></i> Thêm học viên
        </button>
    }
</div>

<!-- ==================== TABLE ==================== -->
<div id="studentTableContainer">
    @await Html.PartialAsync("_StudentTable", Model)
</div>

<!-- ==================== MODAL CREATE / EDIT ==================== -->
<div class="modal fade" id="studentModal" tabindex="-1" aria-labelledby="studentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" style="border:none; border-radius:var(--radius-md); overflow:hidden; box-shadow:var(--shadow-lg);">

            <!-- Header -->
            <div class="modal-header" style="
                background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
                padding:1.25rem 1.5rem; border:none;
            ">
                <h5 id="studentModalLabel" style="
                    font-family:var(--font-display); font-size:1.15rem; font-weight:600;
                    color:var(--gold-light); margin:0;
                ">
                    Thêm học viên
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>

            <!-- Body -->
            <div class="modal-body" style="padding:1.5rem; background:var(--white);">
                <div id="modalResult" style="margin-bottom:1rem;"></div>
                <form id="studentForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="StudentId" name="StudentId" value="0" />

                    <div class="row">
                        <div class="col-md-6">
                            <div class="sa-form-group">
                                <label class="sa-label" for="FullName">
                                    Họ và tên <span style="color:var(--danger)">*</span>
                                </label>
                                <input type="text" id="FullName" name="FullName"
                                       class="sa-input" placeholder="Nhập họ tên (2–100 ký tự)" />
                                <div class="invalid-feedback" id="err-FullName"></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="sa-form-group">
                                <label class="sa-label" for="Email">
                                    Email <span style="color:var(--danger)">*</span>
                                </label>
                                <input type="email" id="Email" name="Email"
                                       class="sa-input" placeholder="example@email.com" />
                                <div class="invalid-feedback" id="err-Email"></div>
                            </div>
                        </div>
                    </div>

                    <div class="row" id="passwordRow">
                        <div class="col-md-6">
                            <div class="sa-form-group">
                                <label class="sa-label" for="Password">
                                    Mật khẩu <span style="color:var(--danger)">*</span>
                                </label>
                                <input type="password" id="Password" name="Password"
                                       class="sa-input" placeholder="Tối thiểu 6 ký tự" />
                                <div class="invalid-feedback" id="err-Password"></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="sa-form-group">
                                <label class="sa-label" for="Phone">
                                    Số điện thoại <span style="color:var(--danger)">*</span>
                                </label>
                                <input type="text" id="Phone" name="Phone"
                                       class="sa-input" placeholder="9–15 ký tự" />
                                <div class="invalid-feedback" id="err-Phone"></div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="sa-form-group">
                                <label class="sa-label" for="DateOfBirth">
                                    Ngày sinh
                                </label>
                                <input type="date" id="DateOfBirth" name="DateOfBirth"
                                       class="sa-input" />
                                <div class="invalid-feedback" id="err-DateOfBirth"></div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="sa-form-group">
                                <label class="sa-label" for="Address">Địa chỉ</label>
                                <input type="text" id="Address" name="Address"
                                       class="sa-input" placeholder="Nhập địa chỉ..." />
                                <div class="invalid-feedback" id="err-Address"></div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Footer -->
            <div class="modal-footer" style="
                padding:1rem 1.5rem;
                background:var(--off-white);
                border-top:1px solid var(--smoke);
            ">
                <button type="button" class="sa-btn sa-btn-outline" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="sa-btn sa-btn-primary" id="btnSaveStudent">
                    <i class="bi bi-check-lg"></i> <span class="btn-text">Lưu</span>
                </button>
            </div>

        </div>
    </div>
</div>

<!-- ==================== MODAL CHI TIẾT ==================== -->
<div class="modal fade" id="studentDetailModal" tabindex="-1" aria-labelledby="studentDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" style="border:none; border-radius:var(--radius-md); overflow:hidden; box-shadow:var(--shadow-lg);">

            <!-- Header -->
            <div class="modal-header" style="
                background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
                padding:1.25rem 1.5rem; border:none;
            ">
                <h5 id="studentDetailModalLabel" style="
                    font-family:var(--font-display); font-size:1.15rem; font-weight:600;
                    color:var(--gold-light); margin:0;
                ">
                    👤 Chi tiết học viên
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>

            <!-- Body -->
            <div class="modal-body" id="studentDetailBody" style="padding:1.5rem; background:var(--white);">
                <div style="text-align:center; padding:2rem 0;">
                    <div class="spinner-border" style="color:var(--gold);" role="status"></div>
                    <p style="margin-top:.75rem; color:var(--text-light);">Đang tải...</p>
                </div>
            </div>

            <!-- Footer -->
            <div class="modal-footer" style="
                padding:1rem 1.5rem;
                background:var(--off-white);
                border-top:1px solid var(--smoke);
            ">
                <button type="button" class="sa-btn sa-btn-outline" data-bs-dismiss="modal">Đóng</button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <form id="antiForgeryForm">@Html.AntiForgeryToken()</form>
    <script>
        var isEditMode = false;

        // ====== MỞ MODAL CHI TIẾT ======
        function openDetailModal(id) {
            $('#studentDetailBody').html(
                '<div style="text-align:center; padding:2rem 0;">' +
                '<div class="spinner-border" style="color:var(--gold);" role="status"></div>' +
                '<p style="margin-top:.75rem; color:var(--text-light);">Đang tải...</p></div>'
            );
            $('#studentDetailModal').modal('show');

            $.get('@Url.Action("GetStudentDetails", "Student")/' + id, function (data) {
                var enrollHtml = '';
                if (data.enrollments.length === 0) {
                    enrollHtml = '<tr><td colspan="3" style="text-align:center; color:var(--text-light); padding:1.25rem;">Chưa đăng ký khóa học nào</td></tr>';
                } else {
                    $.each(data.enrollments, function (_, e) {
                        enrollHtml +=
                            '<tr>' +
                            '<td>' + $('<span>').text(e.courseName).html() + '</td>' +
                            '<td>' + $('<span>').text(e.enrollDate).html() + '</td>' +
                            '<td>' + $('<span>').text(e.grade).html() + '</td>' +
                            '</tr>';
                    });
                }

                $('#studentDetailBody').html(
                    '<div style="display:grid; grid-template-columns:1fr 1fr; gap:.75rem 2rem; margin-bottom:1.5rem;">' +
                        '<div><span class="sa-label" style="margin-bottom:2px;">Họ và tên</span><div style="font-weight:600; color:var(--text-dark);">' + $('<span>').text(data.fullName).html() + '</div></div>' +
                        '<div><span class="sa-label" style="margin-bottom:2px;">Email</span><div style="color:var(--text-dark);">' + $('<span>').text(data.email).html() + '</div></div>' +
                        '<div><span class="sa-label" style="margin-bottom:2px;">Số điện thoại</span><div style="color:var(--text-dark);">' + $('<span>').text(data.phone).html() + '</div></div>' +
                        '<div><span class="sa-label" style="margin-bottom:2px;">Ngày sinh</span><div style="color:var(--text-dark);">' + $('<span>').text(data.dateOfBirth).html() + '</div></div>' +
                        '<div><span class="sa-label" style="margin-bottom:2px;">Địa chỉ</span><div style="color:var(--text-dark);">' + $('<span>').text(data.address).html() + '</div></div>' +
                        '<div><span class="sa-label" style="margin-bottom:2px;">Ngày đăng ký</span><div style="color:var(--text-dark);">' + $('<span>').text(data.registeredDate).html() + '</div></div>' +
                    '</div>' +
                    '<div style="height:1px; background:var(--smoke); margin-bottom:1.25rem;"></div>' +
                    '<h6 style="font-family:var(--font-display); font-weight:600; color:var(--navy); margin-bottom:.75rem;">📚 Khóa học đã đăng ký</h6>' +
                    '<div class="sa-table-wrap"><table class="sa-table">' +
                    '<thead><tr><th>Khóa học</th><th>Ngày đăng ký</th><th>Điểm</th></tr></thead>' +
                    '<tbody>' + enrollHtml + '</tbody>' +
                    '</table></div>'
                );
            }).fail(function () {
                $('#studentDetailBody').html(
                    '<div class="sa-alert sa-alert-danger"><span class="sa-alert-icon"><i class="bi bi-exclamation-circle-fill"></i></span><span>Không thể tải thông tin học viên!</span></div>'
                );
            });
        }

        function clearErrors() {
            $('#modalResult').html('');
            $('#studentForm .sa-input').removeClass('is-invalid');
            $('#studentForm [id^="err-"]').text('');
        }

        // ====== MỞ MODAL TẠO MỚI ======
        function openCreateModal() {
            isEditMode = false;
            $('#studentModalLabel').text('➕ Thêm học viên mới');
            $('#btnSaveStudent .btn-text').text('Lưu');
            $('#studentForm')[0].reset();
            $('#StudentId').val(0);
            clearErrors();
            $('#passwordRow').show();
            $('#Email').closest('.col-md-6').show();
            $('#Email').prop('disabled', false).attr('name', 'Email');
            $('#Password').prop('disabled', false).attr('name', 'Password');
        }

        // ====== MỞ MODAL CHỈNH SỬA ======
        function openEditModal(id) {
            isEditMode = true;
            $('#studentModalLabel').text('✏️ Sửa học viên');
            $('#btnSaveStudent .btn-text').text('Cập nhật');
            clearErrors();

            $.get('@Url.Action("GetStudent", "Student")/' + id, function (data) {
                $('#StudentId').val(data.studentId);
                $('#FullName').val(data.fullName);
                $('#Email').val(data.email);
                $('#Phone').val(data.phone);
                $('#DateOfBirth').val(data.dateOfBirth);
                $('#Address').val(data.address);
                $('#passwordRow').hide();
                $('#Password').prop('disabled', true).removeAttr('name');
                $('#Email').prop('disabled', true).removeAttr('name');
                $('#studentModal').modal('show');
            }).fail(function () {
                showToast('Không thể tải thông tin học viên!', 'danger');
            });
        }

        $(function () {
            $(document).on('input change', '#studentForm input, #studentForm textarea', function () {
                $(this).removeClass('is-invalid');
                $('#err-' + $(this).attr('id')).text('');
                $('#modalResult').html('');
            });

            // ====== LƯU ======
            $('#btnSaveStudent').on('click', function () {
                clearErrors();
                var url = isEditMode
                    ? '@Url.Action("EditAjax", "Student")'
                    : '@Url.Action("CreateAjax", "Student")';

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: $('#studentForm').serialize(),
                    success: function (res) {
                        if (res.success) {
                            $('#studentModal').modal('hide');
                            showToast(res.message, 'success');
                            loadStudents(1);
                        } else if (res.errors) {
                            $.each(res.errors, function (field, messages) {
                                $('#' + field).addClass('is-invalid');
                                $('#err-' + field).text(messages.join(', '));
                            });
                        } else {
                            $('#modalResult').html(
                                '<div class="sa-alert sa-alert-danger"><span class="sa-alert-icon"><i class="bi bi-exclamation-circle-fill"></i></span><span>' + $('<span>').text(res.message).html() + '</span></div>'
                            );
                        }
                    },
                    error: function (xhr) {
                        if (xhr.status === 403) showToast('Bạn không có quyền Admin!', 'danger');
                        else showToast('Lỗi: ' + xhr.statusText, 'danger');
                    }
                });
            });

            // ====== TÌM KIẾM ======
            $('#searchForm').on('submit', function (e) {
                e.preventDefault();
                loadStudents(1);
            });

            // ====== PHÂN TRANG ======
            $(document).on('click', '.ajax-page-link', function (e) {
                e.preventDefault();
                var match = $(this).attr('href').match(/page=(\d+)/);
                loadStudents(match ? match[1] : 1);
            });

            // ====== XÓA ======
            $(document).on('click', '.btn-delete-student', function () {
                if (!confirm('Bạn có chắc muốn xóa học viên này?')) return;
                var id = $(this).data('id');
                var token = $('#antiForgeryForm input[name="__RequestVerificationToken"]').val();
                $.ajax({
                    url: '@Url.Action("DeleteAjax", "Student")',
                    type: 'POST',
                    data: { id: id, __RequestVerificationToken: token },
                    success: function (res) {
                        if (res.success) { showToast(res.message, 'success'); loadStudents(1); }
                        else { showToast(res.message, 'danger'); }
                    },
                    error: function (xhr) {
                        if (xhr.status === 403) showToast('Bạn không có quyền Admin!', 'danger');
                        else showToast('Lỗi: ' + xhr.statusText, 'danger');
                    }
                });
            });

            // ====== LOAD BẢNG ======
            function loadStudents(page) {
                var searchTerm = $('#searchForm input[name="searchTerm"]').val();
                $.ajax({
                    url: '@Url.Action("Index", "Student")',
                    type: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    data: { searchTerm: searchTerm, page: page },
                    success: function (html) {
                        $('#studentTableContainer').html(html);
                    },
                    error: function (xhr) {
                        showToast('Lỗi tải dữ liệu: ' + xhr.statusText, 'danger');
                    }
                });
            }

            // ====== TOAST ======
            window.showToast = function (message, type) {
                var cls = type === 'success' ? 'sa-alert-success' : 'sa-alert-danger';
                var icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-circle-fill';
                var toast = $('<div class="sa-alert ' + cls + '" style="position:fixed; top:1rem; right:1rem; z-index:9999; min-width:300px; max-width:450px; box-shadow:var(--shadow-md);">' +
                    '<span class="sa-alert-icon"><i class="bi ' + icon + '"></i></span>' +
                    '<span>' + $('<span>').text(message).html() + '</span>' +
                    '<button class="sa-alert-close" onclick="$(this).parent().remove()"><i class="bi bi-x"></i></button>' +
                    '</div>');
                $('body').append(toast);
                setTimeout(function () { toast.fadeOut(300, function () { $(this).remove(); }); }, 3000);
            };
        });
    </script>
}
