@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<SchoolApp.Models.Course>
@{
    ViewData["Title"] = "Danh sách khóa học";
    var role = Context.Session.GetString("Role");
    var isAdmin = role == "Admin";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">📚 Danh sách khóa học</h2>
        @if (isAdmin)
        {
            <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#courseModal"
                    onclick="openCreateModal()">
                ➕ Thêm khóa học
            </button>
        }
    </div>

    <form id="searchForm" method="get" class="mb-3">
        <div class="input-group w-50">
            <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]"
                   class="form-control" placeholder="🔍 Tìm khóa học..." />
            <button type="submit" class="btn btn-primary">Tìm</button>
        </div>
    </form>

    <div id="courseTableContainer">
        @await Html.PartialAsync("_CourseTable", Model)
    </div>
</div>

<!-- ==================== MODAL CREATE / EDIT ==================== -->
<div class="modal fade" id="courseModal" tabindex="-1" aria-labelledby="courseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="courseModalLabel">Thêm khóa học</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="modalResult" class="mb-3"></div>
                <form id="courseForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="CourseId" name="CourseId" value="0" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="CourseName" class="form-label fw-semibold">
                                Tên khóa học <span class="text-danger">*</span>
                            </label>
                            <input type="text" id="CourseName" name="CourseName"
                                   class="form-control" placeholder="Nhập tên khóa học (3–200 ký tự)" />
                            <div class="invalid-feedback" id="err-CourseName"></div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label for="Credits" class="form-label fw-semibold">
                                Tín chỉ <span class="text-danger">*</span>
                            </label>
                            <input type="number" id="Credits" name="Credits"
                                   class="form-control" min="1" max="10" placeholder="1–10" />
                            <div class="invalid-feedback" id="err-Credits"></div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label for="FeeDisplay" class="form-label fw-semibold">
                                Học phí (VNĐ) <span class="text-danger">*</span>
                            </label>
                            <!-- Input hiển thị có dấu chấm — KHÔNG có name -->
                            <input type="text" id="FeeDisplay"
                                   class="form-control" placeholder="0–100.000.000"
                                   inputmode="numeric" autocomplete="off" />
                            <!-- Hidden input mang giá trị số thực để submit -->
                            <input type="hidden" id="Fee" name="Fee" />
                            <div class="invalid-feedback" id="err-Fee"></div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="Description" class="form-label fw-semibold">Mô tả</label>
                        <textarea id="Description" name="Description"
                                  class="form-control" rows="3"
                                  placeholder="Mô tả khóa học (tối đa 1000 ký tự)..."></textarea>
                        <div class="invalid-feedback" id="err-Description"></div>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input type="checkbox" id="IsActive" name="IsActive" value="true"
                               class="form-check-input" checked />
                        <label for="IsActive" class="form-check-label fw-semibold">Đang mở đăng ký</label>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnSaveCourse">
                    💾 Lưu
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <form id="antiForgeryForm">@Html.AntiForgeryToken()</form>
    <script>
        var isEditMode = false;

        // ====== FORMAT HỌC PHÍ ======
        function formatFeeDisplay(value) {
            var raw = String(value).replace(/\D/g, '');
            if (raw === '') return '';
            return raw.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
        }

        // Lắng nghe nhập học phí — format realtime
        $(document).on('input', '#FeeDisplay', function () {
            var input = this;
            var oldVal = input.value;
            var pos = input.selectionStart;

            // Đếm số chữ số trước con trỏ trong chuỗi cũ
            var digitsBeforeCursor = oldVal.substring(0, pos).replace(/\D/g, '').length;

            var formatted = formatFeeDisplay(oldVal);
            input.value = formatted;

            // Tính lại vị trí con trỏ sau format
            var newPos = 0, digitCount = 0;
            for (var i = 0; i < formatted.length; i++) {
                if (formatted[i] !== '.') digitCount++;
                if (digitCount === digitsBeforeCursor) { newPos = i + 1; break; }
            }
            input.setSelectionRange(newPos, newPos);

            // Đồng bộ hidden input (số thực)
            $('#Fee').val(formatted.replace(/\./g, ''));

            // Xóa lỗi
            $('#FeeDisplay').removeClass('is-invalid');
            $('#err-Fee').text('');
            $('#modalResult').html('');
        });

        // ====== XÓA LỖI KHI GÕ LẠI (các field khác) ======
        $(document).on('input change', '#courseForm input:not(#FeeDisplay), #courseForm textarea', function () {
            $(this).removeClass('is-invalid');
            var fieldId = $(this).attr('id') || $(this).attr('name');
            $('#err-' + fieldId).text('');
            $('#modalResult').html('');
        });

        // ====== XÓA TẤT CẢ LỖI ======
        function clearErrors() {
            $('#modalResult').html('');
            $('#courseForm .form-control').removeClass('is-invalid');
            $('#FeeDisplay').removeClass('is-invalid');
            $('#courseForm [id^="err-"]').text('');
        }

        // ====== MỞ MODAL TẠO MỚI ======
        function openCreateModal() {
            isEditMode = false;
            $('#courseModalLabel').text('➕ Thêm khóa học mới');
            $('#courseForm')[0].reset();
            $('#CourseId').val(0);
            $('#IsActive').prop('checked', true);
            $('#FeeDisplay').val('');
            $('#Fee').val('');
            clearErrors();
            $('#btnSaveCourse').text('💾 Lưu');
        }

        // ====== MỞ MODAL CHỈNH SỬA ======
        function openEditModal(id) {
            isEditMode = true;
            $('#courseModalLabel').text('✏️ Sửa khóa học');
            $('#btnSaveCourse').text('💾 Cập nhật');
            clearErrors();

            $.get('@Url.Action("GetCourse", "Course")/' + id, function (data) {
                $('#CourseId').val(data.courseId);
                $('#CourseName').val(data.courseName);
                $('#Description').val(data.description);
                $('#Credits').val(data.credits);
                $('#FeeDisplay').val(formatFeeDisplay(String(data.fee)));
                $('#Fee').val(data.fee);
                $('#IsActive').prop('checked', data.isActive);
                $('#courseModal').modal('show');
            }).fail(function () {
                alert('Không thể tải thông tin khóa học!');
            });
        }

        $(function () {
            // ====== LƯU (CREATE hoặc EDIT) ======
            $('#btnSaveCourse').on('click', function () {
                // Đồng bộ số thực vào hidden trước khi submit
                $('#Fee').val($('#FeeDisplay').val().replace(/\./g, ''));
                clearErrors();

                var url = isEditMode
                    ? '@Url.Action("EditAjax", "Course")'
                    : '@Url.Action("CreateAjax", "Course")';

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: $('#courseForm').serialize(),
                    success: function (res) {
                        if (res.success) {
                            $('#courseModal').modal('hide');
                            showToast(res.message, 'success');
                            loadCourses(1);
                        } else if (res.errors) {
                            $.each(res.errors, function (field, messages) {
                                if (field === 'Fee') {
                                    $('#FeeDisplay').addClass('is-invalid');
                                } else {
                                    $('#' + field).addClass('is-invalid');
                                }
                                $('#err-' + field).text(messages.join(', '));
                            });
                        } else {
                            $('#modalResult').html(
                                '<div class="alert alert-danger">' + res.message + '</div>'
                            );
                        }
                    },
                    error: function (xhr) {
                        if (xhr.status === 403) alert('Bạn không có quyền Admin!');
                        else alert('Lỗi: ' + xhr.statusText);
                    }
                });
            });

            // ====== TÌM KIẾM AJAX ======
            $('#searchForm').on('submit', function (e) {
                e.preventDefault();
                loadCourses(1);
            });

            // ====== PHÂN TRANG AJAX ======
            $(document).on('click', '.ajax-page-link', function (e) {
                e.preventDefault();
                var match = $(this).attr('href').match(/page=(\d+)/);
                loadCourses(match ? match[1] : 1);
            });

            // ====== XÓA AJAX ======
            $(document).on('click', '.btn-delete-course', function () {
                if (!confirm('Bạn có chắc muốn xóa khóa học này?')) return;
                var id = $(this).data('id');
                var token = $('#antiForgeryForm input[name="__RequestVerificationToken"]').val();
                $.ajax({
                    url: '@Url.Action("DeleteAjax", "Course")',
                    type: 'POST',
                    data: { id: id, __RequestVerificationToken: token },
                    success: function (res) {
                        if (res.success) {
                            showToast(res.message, 'success');
                            loadCourses(1);
                        } else {
                            showToast(res.message, 'danger');
                        }
                    },
                    error: function (xhr) {
                        if (xhr.status === 403) alert('Bạn không có quyền Admin!');
                        else alert('Lỗi: ' + xhr.statusText);
                    }
                });
            });
                    // ====== ĐĂNG KÝ KHÓA HỌC (Student) ======
        $(document).on('click', '.btn-register-course', function () {
            if (!confirm('Bạn có chắc muốn đăng ký khóa học này?')) return;

            var courseId = $(this).data('id');
            var token = $('#antiForgeryForm input[name="__RequestVerificationToken"]').val();

            $.ajax({
                url: '@Url.Action("Register", "Enrollment")',
                type: 'POST',
                data: { courseId: courseId, __RequestVerificationToken: token },
                success: function (res) {
                    if (res.success) {
                        showToast(res.message, 'success');
                        loadCourses(1); // Reload bảng
                    } else {
                        showToast(res.message, 'danger');
                    }
                },
                error: function (xhr) {
                    if (xhr.status === 403) alert('Bạn không có quyền!');
                    else alert('Lỗi: ' + xhr.statusText); 
                }
            });
        });
            // ====== LOAD BẢNG ======
            function loadCourses(page) {
                var searchTerm = $('#searchForm input[name="searchTerm"]').val();
                $.ajax({
                    url: '@Url.Action("Index", "Course")',
                    type: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    data: { searchTerm: searchTerm, page: page },
                    success: function (html) {
                        $('#courseTableContainer').html(html);
                    }
                });
            }

            // ====== TOAST THÔNG BÁO ======
            window.showToast = function (message, type) {
                var toast = $('<div class="alert alert-' + type +
                    ' alert-dismissible fade show position-fixed top-0 end-0 m-3" style="z-index:9999">' +
                    message +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
                $('body').append(toast);
                setTimeout(function () { toast.alert('close'); }, 3000);
            };
        });
    </script>
}