@using SchoolApp.Models
@model Quiz?

@{
    ViewData["Title"] = "Quản lý Quiz";
    var lessonId = (int)ViewData["LessonId"]!;
    var lessonTitle = ViewData["LessonTitle"] as string;
}

<div class="sa-page-hero">
    <h1>📋 Quiz - @lessonTitle</h1>
    <p>Quản lý câu hỏi và cài đặt bài kiểm tra</p>
</div>

<div class="card">
    <div class="card-body">
        <div id="quizContainer">
            @if (Model == null || Model.QuizId == 0)
            {
                <div class="text-center py-5" id="noQuizBlock">
                    <h4>Chưa có bài kiểm tra cho bài học này</h4>
                    <button class="sa-btn sa-btn-gold mt-3" onclick="openQuizSettingsModal(0)">
                        <i class="bi bi-plus-circle"></i> Tạo bài kiểm tra mới
                    </button>
                </div>
            }
            else
            {
                <div class="d-flex justify-content-between align-items-center mb-4" id="quizHeaderBlock">
                    <h4>
                        <span id="quizTitleDisplay">@Model.Title</span>
                        <span class="badge bg-info" id="questionCountBadge">@Model.Questions.Count câu hỏi</span>
                    </h4>
                    <div>
                        <button class="btn btn-warning btn-sm me-2" onclick="openQuizSettingsModal(@Model.QuizId)">
                            <i class="bi bi-pencil"></i> Sửa cài đặt
                        </button>
                        <button class="btn btn-danger btn-sm" onclick="deleteQuiz(@Model.QuizId)">
                            <i class="bi bi-trash"></i> Xóa Quiz
                        </button>
                    </div>
                </div>
            }
        </div>

        @if (Model != null && Model.QuizId > 0)
        {
            <div id="questionsTableContainer"></div>

            <div class="d-flex justify-content-between mt-3">
                <button class="sa-btn sa-btn-primary" onclick="openCreateQuestionModal()">
                    <i class="bi bi-plus-circle"></i> Thêm câu hỏi mới
                </button>
                <button class="sa-btn sa-btn-outline" onclick="openBankModal()">
                    <i class="bi bi-bank"></i> Thêm từ ngân hàng
                </button>
                <small class="text-muted align-self-end">
                    <i class="bi bi-info-circle"></i> Kéo thả vào cột <i class="bi bi-grip-vertical"></i> để đổi thứ tự câu hỏi
                </small>
            </div>
        }
    </div>
</div>

<!-- ====================== MODAL QUIZ SETTINGS ====================== -->
<div class="modal fade" id="quizModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-navy text-white">
                <h5 class="modal-title" id="quizModalLabel">Cài đặt Quiz</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="quizForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="qz_QuizId" name="QuizId" value="0" />
                    <input type="hidden" id="qz_LessonId" name="LessonId" value="@lessonId" />

                    <div class="row">
                        <div class="col-md-8">
                            <label class="sa-label">Tiêu đề Quiz <span class="text-danger">*</span></label>
                            <input type="text" id="qz_Title" name="Title" class="sa-input" required />
                        </div>
                        <div class="col-md-4">
                            <label class="sa-label">Điểm đạt (%)</label>
                            <input type="number" id="qz_PassingScore" name="PassingScore" class="sa-input" value="70" min="1" max="100" />
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-4">
                            <label class="sa-label">Thời gian (phút, 0 = không giới hạn)</label>
                            <input type="number" id="qz_TimeLimitMinutes" name="TimeLimitMinutes" class="sa-input" value="0" min="0" />
                        </div>
                        <div class="col-md-4">
                            <label class="sa-label">Số lần làm tối đa (0 = không giới hạn)</label>
                            <input type="number" id="qz_MaxAttempts" name="MaxAttempts" class="sa-input" value="0" min="0" />
                        </div>
                        <div class="col-md-4 pt-4">
                            <div class="form-check">
                                <input type="checkbox" id="qz_IsPublished" name="IsPublished" value="true" class="form-check-input" checked />
                                <label class="form-check-label" for="qz_IsPublished">Công bố Quiz</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-2">
                        <div class="col-md-6">
                            <div class="form-check">
                                <input type="checkbox" id="qz_AllowRetry" name="AllowRetry" value="true" class="form-check-input" checked />
                                <label class="form-check-label" for="qz_AllowRetry">Cho phép làm lại</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input type="checkbox" id="qz_ShowAnswersAfterSubmit" name="ShowAnswersAfterSubmit" value="true" class="form-check-input" checked />
                                <label class="form-check-label" for="qz_ShowAnswersAfterSubmit">Hiển thị đáp án sau khi nộp</label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="sa-label">Mô tả / Hướng dẫn</label>
                        <textarea id="qz_Description" name="Description" class="sa-input" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="sa-btn sa-btn-outline" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="sa-btn sa-btn-primary" id="btnSaveQuiz">
                    <i class="bi bi-check-lg"></i> Lưu Quiz
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ====================== MODAL QUESTION + OPTIONS ====================== -->
<div class="modal fade" id="questionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-navy text-white">
                <h5 class="modal-title" id="questionModalLabel">Thêm / Sửa Câu Hỏi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="questionForm">
                    <input type="hidden" id="q_QuestionId" value="0" />

                    <div class="row">
                        <div class="col-md-8">
                            <label class="sa-label">Nội dung câu hỏi <span class="text-danger">*</span></label>
                            <textarea id="q_Content" class="sa-input" rows="3" required></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="sa-label">Loại câu hỏi</label>
                            <select id="q_Type" class="sa-input" onchange="onQuestionTypeChange()">
                                <option value="0">Một đáp án</option>
                                <option value="1">Nhiều đáp án</option>
                                <option value="2">Đúng / Sai</option>
                            </select>

                            <label class="sa-label mt-3">Điểm</label>
                            <input type="number" id="q_Points" class="sa-input" value="1" min="1" max="20" />
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="sa-label">Giải thích đáp án (tùy chọn)</label>
                        <textarea id="q_Explanation" class="sa-input" rows="2"></textarea>
                    </div>

                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <h6 class="mb-0">Đáp án</h6>
                        <small class="text-muted" id="optionsHint">Đánh dấu vào ô <strong>Đúng</strong> cho đáp án chính xác</small>
                    </div>
                    <div id="optionsContainer" class="mt-2"></div>

                    <button type="button" id="btnAddOption" class="btn btn-sm btn-outline-primary mt-2" onclick="addOptionField()">
                        <i class="bi bi-plus"></i> Thêm đáp án
                    </button>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="sa-btn sa-btn-outline" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="sa-btn sa-btn-primary" id="btnSaveQuestion">
                    <i class="bi bi-check-lg"></i> Lưu Câu Hỏi
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ====================== MODAL IMPORT===================== -->

<div class="modal fade" id="bankImportModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header bg-navy text-white">
                <h5 class="modal-title">🗃️ Chọn câu hỏi từ ngân hàng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                @* ── TOOLBAR ─────────────────────────────────────────── *@
                <div class="d-flex gap-2 mb-3 flex-wrap align-items-center">
                    <div style="position:relative; flex:1; min-width:200px;">
                        <i class="bi bi-search"
                           style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#aaa;"></i>
                        <input type="text" id="bankSearchInput" class="sa-input"
                               placeholder="Tìm nội dung câu hỏi..."
                               oninput="filterBankTable()"
                               style="padding-left:32px;" />
                    </div>
                    <select id="bankTagFilter" class="sa-input" style="max-width:180px;"
                            onchange="filterBankTable()">
                        <option value="">-- Tất cả tag --</option>
                    </select>
                    <select id="bankTypeFilter" class="sa-input" style="max-width:170px;"
                            onchange="filterBankTable()">
                        <option value="">-- Tất cả loại --</option>
                        <option value="0">Một đáp án</option>
                        <option value="1">Nhiều đáp án</option>
                        <option value="2">Đúng / Sai</option>
                    </select>
                </div>

                @* ── BẢNG ─────────────────────────────────────────────── *@
                <div style="max-height:420px; overflow-y:auto;">
                    <table class="table table-bordered table-hover align-middle mb-0">
                        <thead class="table-dark" style="position:sticky;top:0;z-index:1;">
                            <tr>
                                <th style="width:40px;">
                                    <input type="checkbox" id="checkAll"
                                           class="form-check-input mt-0"
                                           onchange="toggleCheckAll(this)" />
                                </th>
                                <th>Nội dung câu hỏi</th>
                                <th style="width:130px;">Loại</th>
                                <th style="width:70px;" class="text-center">Điểm</th>
                                <th style="width:100px;">Tag</th>
                            </tr>
                        </thead>
                        <tbody id="bankImportBody">
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    <div class="spinner-border spinner-border-sm me-2"></div>
                                    Đang tải...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                @* ── FOOTER INFO ──────────────────────────────────────── *@
                <div class="d-flex justify-content-between align-items-center mt-2">
                    <small class="text-muted">
                        Hiển thị <strong id="bankVisibleCount">0</strong> câu —
                        Đã chọn: <strong id="bankSelectedCount" class="text-primary">0</strong> câu
                    </small>
                    <small class="text-muted">
                        <i class="bi bi-info-circle me-1"></i>
                        Câu hỏi sẽ được sao chép vào quiz, bản gốc trong ngân hàng không thay đổi
                    </small>
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="sa-btn sa-btn-outline" data-bs-dismiss="modal">Huỷ</button>
                <button type="button" class="sa-btn sa-btn-primary" id="btnImportBank"
                        onclick="importFromBank()" disabled>
                    <i class="bi bi-download me-1"></i>
                    Import <span id="importCount">0</span> câu vào quiz
                </button>
            </div>

        </div>
    </div>
</div>
@section Scripts {
    <form id="antiForgeryForm">@Html.AntiForgeryToken()</form>

    <!-- SortableJS cho drag-drop reorder -->
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

    <script>
        // =========================================================
        // STATE
        // =========================================================
        let currentQuizId   = @((Model?.QuizId ?? 0));
        let currentLessonId = @((int)ViewData["LessonId"]!);
        let isEditQuestion  = false;
        let sortableInstance = null;

        // =========================================================
        // HELPERS
        // =========================================================
        function getAntiForgeryToken() {
            return $('#antiForgeryForm input[name="__RequestVerificationToken"]').val();
        }

        function ajaxJson(url, data) {
            return $.ajax({
                url: url,
                type: 'POST',
                contentType: 'application/json',
                headers: { 'RequestVerificationToken': getAntiForgeryToken() },
                data: JSON.stringify(data)
            });
        }

        window.showToast = function (message, type = 'success') {
            const cls = type === 'success' ? 'sa-alert-success' : 'sa-alert-danger';
            const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-circle-fill';
            const toast = $(`
                <div class="sa-alert ${cls}" style="position:fixed;top:1rem;right:1rem;z-index:9999;min-width:320px;">
                    <span class="sa-alert-icon"><i class="bi ${icon}"></i></span>
                    <span>${message}</span>
                    <button class="sa-alert-close" onclick="$(this).parent().remove()"><i class="bi bi-x"></i></button>
                </div>`);
            $('body').append(toast);
            setTimeout(() => toast.fadeOut(400, () => toast.remove()), 3000);
        };

        // =========================================================
        // LOAD QUESTIONS LIST
        // =========================================================
        function loadQuestions() {
            if (currentQuizId === 0) return;
            $.get('@Url.Action("GetQuestions", "Quiz")', { quizId: currentQuizId }, function (html) {
                $('#questionsTableContainer').html(html);

                const count = $('#questionsTbody tr[data-question-id]').length;
                $('#questionCountBadge').text(count + ' câu hỏi');

                initSortable();
            });
        }

        // =========================================================
        // SORTABLE / REORDER
        // =========================================================
        function initSortable() {
            const tbody = document.getElementById('questionsTbody');
            if (!tbody) return;

            // Destroy old instance nếu có
            if (sortableInstance) {
                sortableInstance.destroy();
                sortableInstance = null;
            }

            sortableInstance = Sortable.create(tbody, {
                handle: '.drag-handle',
                animation: 150,
                ghostClass: 'table-warning',
                onEnd: function () {
                    const ids = $('#questionsTbody tr[data-question-id]')
                        .map(function () { return parseInt($(this).data('question-id')); })
                        .get();

                    if (ids.length === 0) return;

                    // Cập nhật UI ngay (optimistic)
                    $('#questionsTbody tr[data-question-id]').each(function (i) {
                        $(this).find('.order-cell').text(i + 1);
                    });

                    ajaxJson('@Url.Action("ReorderQuestions", "Quiz")',
                        { QuizId: currentQuizId, QuestionIds: ids })
                        .done(function (res) {
                            if (res.success) {
                                showToast(res.message || 'Đã cập nhật thứ tự', 'success');
                            } else {
                                showToast(res.message || 'Lỗi cập nhật thứ tự', 'danger');
                                loadQuestions(); // rollback bằng cách reload
                            }
                        })
                        .fail(function () {
                            showToast('Lỗi kết nối', 'danger');
                            loadQuestions();
                        });
                }
            });
        }

        // =========================================================
        // QUIZ SETTINGS MODAL
        // =========================================================
        function openQuizSettingsModal(quizId) {
            $('#quizForm')[0].reset();
            $('#qz_QuizId').val(quizId || 0);
            $('#qz_LessonId').val(currentLessonId);

            if (quizId && quizId > 0) {
                $('#quizModalLabel').text('✏️ Sửa cài đặt Quiz');
                $.get('@Url.Action("GetQuiz", "Quiz")', { id: quizId }, function (data) {
                    $('#qz_Title').val(data.title);
                    $('#qz_Description').val(data.description || '');
                    $('#qz_PassingScore').val(data.passingScore);
                    $('#qz_TimeLimitMinutes').val(data.timeLimitMinutes);
                    $('#qz_MaxAttempts').val(data.maxAttempts);
                    $('#qz_IsPublished').prop('checked', data.isPublished);
                    $('#qz_AllowRetry').prop('checked', data.allowRetry);
                    $('#qz_ShowAnswersAfterSubmit').prop('checked', data.showAnswersAfterSubmit);
                    $('#quizModal').modal('show');
                }).fail(function () {
                    showToast('Không tải được thông tin Quiz!', 'danger');
                });
            } else {
                $('#quizModalLabel').text('➕ Tạo bài kiểm tra mới');
                $('#qz_PassingScore').val(70);
                $('#qz_IsPublished').prop('checked', true);
                $('#qz_AllowRetry').prop('checked', true);
                $('#qz_ShowAnswersAfterSubmit').prop('checked', true);
                $('#quizModal').modal('show');
            }
        }

                       $('#btnSaveQuiz').on('click', function () {
            const formData = $('#quizForm').serializeArray();

            $.ajax({
                url: '@Url.Action("SaveQuiz", "Quiz")',
                type: 'POST',
                data: $.param(formData),
                success: function (res) {
                    if (res.success) {
                        $('#quizModal').modal('hide');
                        showToast(res.message, 'success');
                        setTimeout(() => location.reload(), 700);
                    } else {
                        console.log(res.errors);
                        showToast(res.message || 'Lưu thất bại', 'danger');
                    }
                },
                error: function () {
                    showToast('Lỗi kết nối!', 'danger');
                }
            });
        });

        function deleteQuiz(quizId) {
            if (!confirm('Xóa bài kiểm tra này? Toàn bộ câu hỏi sẽ bị xóa theo.')) return;
            $.ajax({
                url: '@Url.Action("Delete", "Quiz")',
                type: 'POST',
                data: { id: quizId, __RequestVerificationToken: getAntiForgeryToken() },
                success: function (res) {
                    if (res.success) {
                        showToast(res.message, 'success');
                        setTimeout(() => location.reload(), 600);
                    } else {
                        showToast(res.message, 'danger');
                    }
                }
            });
        }

        // =========================================================
        // QUESTION MODAL
        // =========================================================
               function onQuestionTypeChange() {
            const type = parseInt($('#q_Type').val());
            const isTrueFalse = type === 2;

            if (isTrueFalse) {
                $('#btnAddOption').hide();
                $('#optionsHint').html('Câu Đúng/Sai có cố định 2 đáp án. Chỉ được chọn 1 đáp án đúng.');

                // ✅ Chỉ hard-code khi TẠO MỚI, còn edit thì giữ nguyên options đã load
                if (!isEditQuestion && $('#optionsContainer .option-item').length === 0) {
                    $('#optionsContainer').html('');
                    addOptionField('Đúng', true, 0);   // Mặc định "Đúng" là đúng
                    addOptionField('Sai', false, 0);
                }

                // Force radio
                $('#optionsContainer .option-correct').attr('type', 'radio').attr('name', 'tf_correct');
            }
            else {
                $('#btnAddOption').show();
                $('#optionsHint').html(
                    type === 1
                        ? 'Đánh dấu vào ô <strong>Đúng</strong> cho TẤT CẢ đáp án chính xác'
                        : 'Đánh dấu vào ô <strong>Đúng</strong> cho 1 đáp án chính xác'
                );
                $('#optionsContainer .option-correct').attr('type', 'checkbox').removeAttr('name');
            }
        }

        function openCreateQuestionModal() {
            if (currentQuizId === 0) {
                showToast('Vui lòng tạo Quiz trước khi thêm câu hỏi', 'danger');
                return;
            }
            isEditQuestion = false;
            $('#questionModalLabel').text('➕ Thêm câu hỏi mới');
            $('#btnSaveQuestion').html('<i class="bi bi-check-lg"></i> Lưu Câu Hỏi');
            $('#questionForm')[0].reset();
            $('#q_QuestionId').val(0);
            $('#q_Type').val(0);
            $('#optionsContainer').html('');
            addOptionField();
            addOptionField();
            onQuestionTypeChange();
            $('#questionModal').modal('show');
        }

        function editQuestion(questionId) {
            isEditQuestion = true;
            $('#questionModalLabel').text('✏️ Sửa câu hỏi');
            $('#btnSaveQuestion').html('<i class="bi bi-check-lg"></i> Cập nhật');
            $('#optionsContainer').html('');

            $.get('@Url.Action("GetQuestion", "Quiz")', { id: questionId }, function (data) {
                $('#q_QuestionId').val(data.questionId);
                $('#q_Content').val(data.content);
                $('#q_Type').val(data.type);
                $('#q_Points').val(data.points);
                $('#q_Explanation').val(data.explanation || '');

                if (data.options && data.options.length > 0) {
                    data.options.forEach(o => addOptionField(o.content, o.isCorrect, o.answerOptionId));
                } else {
                    addOptionField();
                    addOptionField();
                }
                onQuestionTypeChange();
                $('#questionModal').modal('show');
            }).fail(function () {
                showToast('Không tải được thông tin câu hỏi!', 'danger');
            });
        }

        function addOptionField(content = '', isCorrect = false, answerOptionId = 0) {
            const safeContent = $('<div>').text(content).html();
            const optionHtml = `
                <div class="option-item input-group mb-2" data-option-id="${answerOptionId}">
                    <input type="text" class="form-control option-content" placeholder="Nội dung đáp án" value="${safeContent}">
                    <div class="input-group-text">
                        <input type="checkbox" class="option-correct form-check-input mt-0 me-2" ${isCorrect ? 'checked' : ''}>
                        <span>Đúng</span>
                    </div>
                    <button type="button" class="btn btn-outline-danger" onclick="$(this).closest('.option-item').remove()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>`;
            $('#optionsContainer').append(optionHtml);
        }

        $('#btnSaveQuestion').on('click', function () {
            const type = parseInt($('#q_Type').val());

            const options = [];
            $('.option-item').each(function () {
                const content = $(this).find('.option-content').val().trim();
                const isCorrect = $(this).find('.option-correct').is(':checked');
                const optionId = parseInt($(this).data('option-id')) || 0;

                if (content) {
                    options.push({
                        AnswerOptionId: optionId,
                        Content: content,
                        IsCorrect: isCorrect
                    });
                }
            });

            const payload = {
                QuestionId: parseInt($('#q_QuestionId').val()) || 0,
                QuizId: currentQuizId,
                Content: $('#q_Content').val(),
                Type: type,
                Points: parseInt($('#q_Points').val()) || 1,
                Explanation: $('#q_Explanation').val(),
                Options: options
            };

            const url = isEditQuestion
                ? '@Url.Action("EditQuestion", "Quiz")'
                : '@Url.Action("CreateQuestion", "Quiz")';

            ajaxJson(url, payload)
                .done(function (res) {
                    if (res.success) {
                        $('#questionModal').modal('hide');
                        showToast(res.message, 'success');
                        loadQuestions();
                    } else {
                        showToast(res.message || 'Lưu thất bại', 'danger');
                    }
                })
                .fail(function () { showToast('Lỗi kết nối!', 'danger'); });
        });

        function deleteQuestion(questionId) {
            if (!confirm('Xóa câu hỏi này?')) return;
            $.ajax({
                url: '@Url.Action("DeleteQuestion", "Quiz")',
                type: 'POST',
                data: { id: questionId, __RequestVerificationToken: getAntiForgeryToken() },
                success: function (res) {
                    if (res.success) {
                        showToast(res.message, 'success');
                        loadQuestions();
                    } else {
                        showToast(res.message, 'danger');
                    }
                }
            });
        }
                window.copyToBank = function (questionId) {
            if (!confirm('Lưu câu hỏi này vào ngân hàng?')) return;

            $.ajax({
                url: '@Url.Action("CopyToBank", "Quiz")',
                type: 'POST',
                data: {
                    questionId: questionId,
                    __RequestVerificationToken: getAntiForgeryToken()
                },
                success: function (res) {
                    if (res.success) {
                        showToast(res.message, 'success');
                    } else {
                        showToast(res.message, 'danger');
                    }
                },
                error: () => showToast('Lỗi kết nối!', 'danger')
            });
        };
        // =========================================================
        // INIT
        // =========================================================
        $(function () {
            if (currentQuizId > 0) {
                loadQuestions();
            }
        });

                // ── STATE ─────────────────────────────────────────────────────────────
        let allBankQuestions = [];

        // ── MỞ MODAL ──────────────────────────────────────────────────────────
        window.openBankModal = function () {
            if (currentQuizId === 0) {
                showToast('Vui lòng tạo Quiz trước!', 'danger');
                return;
            }

            // Reset UI
            $('#bankSearchInput').val('');
            $('#bankTagFilter').val('');
            $('#bankTypeFilter').val('');
            $('#checkAll').prop('checked', false);
            updateImportButton();

            // Load data rồi mở modal
            $.get('/QuestionBank/GetAll')
                .done(function (data) {
                    allBankQuestions = data;
                    populateTagFilter(data);
                    renderBankTable(data);
                    $('#bankImportModal').modal('show');
                })
                .fail(() => showToast('Không tải được ngân hàng câu hỏi!', 'danger'));
        };

        // ── RENDER TAG FILTER ──────────────────────────────────────────────────
        function populateTagFilter(list) {
            const tags = [...new Set(list.map(q => q.tag).filter(Boolean))].sort();
            const sel  = $('#bankTagFilter');
            sel.find('option:not(:first)').remove();
            tags.forEach(t => sel.append(`<option value="${t}">${t}</option>`));
        }

        // ── RENDER BẢNG ───────────────────────────────────────────────────────
        function renderBankTable(list) {
            const typeLabel = { 0: 'Một đáp án', 1: 'Nhiều đáp án', 2: 'Đúng / Sai' };
            const typeBadge = {
                0: 'bg-primary',
                1: 'bg-warning text-dark',
                2: 'bg-info text-dark'
            };

            const tbody = $('#bankImportBody');

            if (list.length === 0) {
                tbody.html(`
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            <i class="bi bi-inbox d-block fs-2 mb-1"></i>
                            Không có câu hỏi nào phù hợp
                        </td>
                    </tr>`);
                $('#bankVisibleCount').text(0);
                return;
            }

            tbody.html(list.map(q => `
                <tr data-id="${q.questionId}"
                    data-content="${(q.content ?? '').toLowerCase()}"
                    data-tag="${q.tag ?? ''}"
                    data-type="${q.type}">
                    <td>
                        <input type="checkbox" class="form-check-input bank-cb mt-0"
                               value="${q.questionId}"
                               onchange="updateImportButton()" />
                    </td>
                    <td>
                        <div class="fw-medium">${escapeHtml(q.content)}</div>
                        ${q.optionCount ? `<small class="text-muted">${q.optionCount} đáp án</small>` : ''}
                    </td>
                    <td>
                        <span class="badge ${typeBadge[q.type] ?? 'bg-secondary'}">
                            ${typeLabel[q.type] ?? ''}
                        </span>
                    </td>
                    <td class="text-center">${q.points}</td>
                    <td>
                        ${q.tag
                            ? `<span class="badge bg-secondary"><i class="bi bi-tag me-1"></i>${escapeHtml(q.tag)}</span>`
                            : ''}
                    </td>
                </tr>`).join(''));

            $('#bankVisibleCount').text(list.length);
            updateImportButton();
        }

        // ── FILTER ────────────────────────────────────────────────────────────
        function filterBankTable() {
            const kw   = $('#bankSearchInput').val().toLowerCase().trim();
            const tag  = $('#bankTagFilter').val();
            const type = $('#bankTypeFilter').val();

            const filtered = allBankQuestions.filter(q => {
                const matchKw   = !kw   || (q.content ?? '').toLowerCase().includes(kw);
                const matchTag  = !tag  || q.tag === tag;
                const matchType = type === '' || String(q.type) === type;
                return matchKw && matchTag && matchType;
            });

            renderBankTable(filtered);
        }

        // ── CHECK ALL ─────────────────────────────────────────────────────────
        window.toggleCheckAll = function (master) {
            $('.bank-cb').prop('checked', master.checked);
            updateImportButton();
        };

        // ── CẬP NHẬT NÚT IMPORT ──────────────────────────────────────────────
        function updateImportButton() {
            const count = $('.bank-cb:checked').length;
            $('#bankSelectedCount').text(count);
            $('#importCount').text(count);
            $('#btnImportBank').prop('disabled', count === 0);
        }

        // ── IMPORT ────────────────────────────────────────────────────────────
        window.importFromBank = function () {
            const ids = $('.bank-cb:checked').map(function () {
                return parseInt($(this).val());
            }).get();

            if (ids.length === 0) {
                showToast('Chưa chọn câu hỏi nào!', 'danger');
                return;
            }

            $('#btnImportBank').prop('disabled', true)
                .html('<span class="spinner-border spinner-border-sm me-1"></span> Đang import...');

            $.ajax({
                url: '/QuestionBank/ImportToQuiz',
                type: 'POST',
                contentType: 'application/json',
                headers: { 'RequestVerificationToken': getAntiForgeryToken() },
                data: JSON.stringify({ quizId: currentQuizId, bankQuestionIds: ids }),
                success: function (res) {
                    if (res.success) {
                        $('#bankImportModal').modal('hide');
                        showToast(res.message, 'success');
                        loadQuestions();   // reload bảng câu hỏi quiz
                    } else {
                        showToast(res.message || 'Import thất bại!', 'danger');
                    }
                },
                error: () => showToast('Lỗi kết nối!', 'danger'),
                complete: function () {
                    $('#btnImportBank').prop('disabled', false)
                        .html('<i class="bi bi-download me-1"></i> Import <span id="importCount">' + ids.length + '</span> câu vào quiz');
                }
            });
        };

        // ── HELPER ────────────────────────────────────────────────────────────
        function escapeHtml(str) {
            return $('<div>').text(str ?? '').html();
        }
    </script>
}
                