@using SchoolApp.Models
@model IEnumerable<QuizAttempt>

@{
    ViewData["Title"] = "Lịch sử làm bài";
    var quiz = (Quiz)ViewData["Quiz"]!;
}

<div class="container mt-4">

    @if (TempData["QuizError"] != null)
    {
        <div class="alert alert-warning">@TempData["QuizError"]</div>
    }

    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">
                <i class="bi bi-clock-history"></i>
                Lịch sử: @quiz.Title
            </h4>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox display-4 d-block mb-2"></i>
                    Chưa có lượt làm bài nào.
                    <div class="mt-3">
                        <a href="@Url.Action("Take", new { id = quiz.QuizId })" class="btn btn-primary">
                            <i class="bi bi-play-circle"></i> Bắt đầu làm bài
                        </a>
                    </div>
                </div>
            }
            else
            {
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th class="text-center">Lần</th>
                            <th>Bắt đầu</th>
                            <th>Thời gian làm</th>
                            <th class="text-center">Điểm</th>
                            <th class="text-center">Phần trăm</th>
                            <th class="text-center">Kết quả</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model)
                        {
                            int p = a.MaxScore > 0
                                ? (int)Math.Round((double)a.Score * 100 / a.MaxScore)
                                : 0;
                            <tr>
                                <td class="text-center fw-bold">#@a.AttemptNumber</td>
                                <td>@a.StartedAt.ToLocalTime().ToString("HH:mm dd/MM/yyyy")</td>
                                <td>
                                    @if (a.FinishedAt.HasValue)
                                    {
                                        var dur = a.FinishedAt.Value - a.StartedAt;
                                        @($"{(int)dur.TotalMinutes}p {dur.Seconds}s")
                                    }
                                    else
                                    {
                                        <span class="text-warning">Chưa hoàn thành</span>
                                    }
                                </td>
                                <td class="text-center">@a.Score / @a.MaxScore</td>
                                <td class="text-center fw-bold @(p >= quiz.PassingScore ? "text-success" : "text-danger")">@p%</td>
                                <td class="text-center">
                                    @if (a.Passed)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-lg"></i> Đạt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x-lg"></i> Chưa đạt</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="@Url.Action("Result", new { id = a.QuizAttemptId })"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> Xem
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

              
                    int totalDone = Model.Count();
                    int remaining = quiz.MaxAttempts > 0 ? quiz.MaxAttempts - totalDone : -1;
                    bool canRetry = quiz.AllowRetry && (remaining != 0);
                

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <small class="text-muted">
                        Đã làm: @totalDone lượt
                        @if (remaining > 0) { <span>· Còn lại: @remaining lượt</span> }
                        @if (remaining == -1) { <span>· Không giới hạn</span> }
                    </small>
                    @if (canRetry)
                    {
                        <a href="@Url.Action("Take", new { id = quiz.QuizId })" class="btn btn-primary">
                            <i class="bi bi-arrow-repeat"></i> Làm lại
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>
