@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<SchoolApp.Models.Enrollment>
@{
    ViewData["Title"] = "Danh sách đăng ký";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">📋 Danh sách đăng ký học</h2>
    </div>

    <form id="searchForm" method="get" class="mb-3">
        <div class="input-group w-50">
            <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]"
                   class="form-control" placeholder="🔍 Tìm theo tên học viên hoặc khóa học..." />
            <button type="submit" class="btn btn-primary">Tìm</button>
        </div>
    </form>

    <div id="enrollmentTableContainer">
        @await Html.PartialAsync("_EnrollmentTable", Model)
    </div>
</div>

<!-- ==================== MODAL CHẤM ĐIỂM ==================== -->
<div class="modal fade" id="enrollmentModal" tabindex="-1" aria-labelledby="enrollmentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title" id="enrollmentModalLabel">✏️ Chấm điểm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="modalResult" class="mb-3"></div>
                <form id="enrollmentForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="EnrollmentId" name="EnrollmentId" value="0" />

                    <!-- Thông tin chỉ đọc -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted">Học viên</label>
                        <input type="text" id="StudentName" class="form-control bg-light"
                               readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted">Khóa học</label>
                        <input type="text" id="CourseName" class="form-control bg-light"
                               readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted">Ngày đăng ký</label>
                        <input type="text" id="EnrollDate" class="form-control bg-light"
                               readonly />
                    </div>

                    <hr />

                    <!-- Phần có thể chỉnh sửa -->
                    <div class="mb-3">
                        <label for="Grade" class="form-label fw-semibold">
                            Điểm <span class="text-muted fw-normal">(0 – 10)</span>
                        </label>
                        <input type="number" id="Grade" name="Grade"
                               class="form-control" min="0" max="10" step="0.01"
                               placeholder="Để trống nếu chưa chấm" />
                        <div class="invalid-feedback" id="err-Grade"></div>
                    </div>
                    <div class="mb-3">
                        <label for="Notes" class="form-label fw-semibold">Ghi chú</label>
                        <textarea id="Notes" name="Notes"
                                  class="form-control" rows="3"
                                  placeholder="Nhập ghi chú..."></textarea>
                        <div class="invalid-feedback" id="err-Notes"></div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-warning" id="btnSaveEnrollment">
                    💾 Lưu điểm
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <form id="antiForgeryForm">@Html.AntiForgeryToken()</form>
    <script>
        // ====== XÓA TẤT CẢ LỖI ======
        function clearErrors() {
            $('#modalResult').html('');
            $('#enrollmentForm .form-control').removeClass('is-invalid');
            $('#enrollmentForm [id^="err-"]').text('');
        }

        // ====== MỞ MODAL CHẤM ĐIỂM ======
        function openEditModal(id) {
            clearErrors();

            // Hiện spinner trong khi load
            $('#Grade').val('');
            $('#Notes').val('');
            $('#StudentName').val('Đang tải...');
            $('#CourseName').val('Đang tải...');
            $('#EnrollDate').val('');

            $('#enrollmentModal').modal('show');

            $.get('@Url.Action("GetEnrollment", "Enrollment")/' + id, function (data) {
                $('#EnrollmentId').val(data.enrollmentId);
                $('#StudentName').val(data.studentName);
                $('#CourseName').val(data.courseName);
                $('#EnrollDate').val(data.enrollDate);
                $('#Grade').val(data.grade !== null ? data.grade : '');
                $('#Notes').val(data.notes);
            }).fail(function () {
                $('#enrollmentModal').modal('hide');
                alert('Không thể tải thông tin đăng ký!');
            });
        }

        $(function () {
            // ====== XÓA LỖI KHI GÕ LẠI ======
            $(document).on('input change', '#enrollmentForm input, #enrollmentForm textarea', function () {
                $(this).removeClass('is-invalid');
                $('#err-' + $(this).attr('id')).text('');
                $('#modalResult').html('');
            });

            // ====== LƯU ĐIỂM ======
            $('#btnSaveEnrollment').on('click', function () {
                clearErrors();

                $.ajax({
                    url: '@Url.Action("EditAjax", "Enrollment")',
                    type: 'POST',
                    data: $('#enrollmentForm').serialize(),
                    success: function (res) {
                        if (res.success) {
                            $('#enrollmentModal').modal('hide');
                            showToast(res.message, 'success');
                            loadEnrollments(1);
                        } else if (res.errors) {
                            $.each(res.errors, function (field, messages) {
                                $('#' + field).addClass('is-invalid');
                                $('#err-' + field).text(messages.join(', '));
                            });
                        } else {
                            $('#modalResult').html(
                                '<div class="alert alert-danger">' + res.message + '</div>'
                            );
                        }
                    },
                    error: function (xhr) {
                        if (xhr.status === 403) alert('Bạn không có quyền Admin!');
                        else alert('Lỗi: ' + xhr.statusText);
                    }
                });
            });

            // ====== TÌM KIẾM AJAX ======
            $('#searchForm').on('submit', function (e) {
                e.preventDefault();
                loadEnrollments(1);
            });

            // ====== PHÂN TRANG AJAX ======
            $(document).on('click', '.ajax-page-link', function (e) {
                e.preventDefault();
                var match = $(this).attr('href').match(/page=(\d+)/);
                loadEnrollments(match ? match[1] : 1);
            });

            // ====== XÓA AJAX ======
            $(document).on('click', '.btn-delete-enrollment', function () {
                if (!confirm('Bạn có chắc muốn xóa đăng ký này?')) return;
                var id = $(this).data('id');
                var token = $('#antiForgeryForm input[name="__RequestVerificationToken"]').val();
                $.ajax({
                    url: '@Url.Action("DeleteAjax", "Enrollment")',
                    type: 'POST',
                    data: { id: id, __RequestVerificationToken: token },
                    success: function (res) {
                        if (res.success) {
                            showToast(res.message, 'success');
                            loadEnrollments(1);
                        } else {
                            showToast(res.message, 'danger');
                        }
                    },
                    error: function (xhr) {
                        if (xhr.status === 403) alert('Bạn không có quyền Admin!');
                        else alert('Lỗi: ' + xhr.statusText);
                    }
                });
            });

            // ====== LOAD BẢNG ======
            function loadEnrollments(page) {
                var searchTerm = $('#searchForm input[name="searchTerm"]').val();
                $.ajax({
                    url: '@Url.Action("Index", "Enrollment")',
                    type: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    data: { searchTerm: searchTerm, page: page },
                    success: function (html) {
                        $('#enrollmentTableContainer').html(html);
                    },
                    error: function (xhr) {
                        alert('Lỗi tải dữ liệu: ' + xhr.statusText);
                    }
                });
            }

            // ====== TOAST THÔNG BÁO ======
            window.showToast = function (message, type) {
                var toast = $('<div class="alert alert-' + type +
                    ' alert-dismissible fade show position-fixed top-0 end-0 m-3" style="z-index:9999">' +
                    message +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
                $('body').append(toast);
                setTimeout(function () { toast.alert('close'); }, 3000);
            };
        });
    </script>
}