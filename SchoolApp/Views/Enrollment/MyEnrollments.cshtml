@model IEnumerable<SchoolApp.Models.Enrollment>
@{
    ViewData["Title"] = "Khóa học của tôi";
}

<h2>Khóa học của tôi</h2>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">
        Bạn chưa đăng ký khóa học nào.
        <a asp-controller="Course" asp-action="Index" class="alert-link">Xem danh sách khóa học</a>
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Tên khóa học</th>
                <th>Tín chỉ</th>
                <th>Học phí</th>
                <th>Ngày đăng ký</th>
                <th>Điểm</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @{
                int i = 1;
            }
            @foreach (var e in Model)
            {
                <tr>
                    <td>@i</td>
                    <td>@e.Course?.CourseName</td>
                    <td>@e.Course?.Credits</td>
                    <td>@e.Course?.Fee.ToString("N0") VNĐ</td>
                    <td>@e.EnrollDate.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (e.Grade.HasValue)
                        {
                            <span class="badge bg-primary">@e.Grade.Value.ToString("0.00")</span>
                        }
                        else
                        {
                            <span class="text-muted">Chưa có</span>
                        }
                    </td>
                    <td>
                        @if (e.Course?.IsActive == true)
                        {
                            <span class="badge bg-success">Đang học</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Đã đóng</span>
                        }
                    </td>
                </tr>
                i++;
            }
        </tbody>
    </table>
}

<a asp-controller="Course" asp-action="Index" class="btn btn-primary">Đăng ký thêm khóa học</a>