@model SchoolApp.Models.Enrollment
@{
    ViewData["Title"] = "Chấm điểm";
}

<h2>Chấm điểm học viên</h2>
<hr />

<div class="row">
    <div class="col-md-8">
        <div class="card mb-3">
            <div class="card-body">
                <p><strong>Học viên:</strong> @Model.Student?.FullName</p>
                <p><strong>Khóa học:</strong> @Model.Course?.CourseName</p>
                <p class="mb-0"><strong>Ngày đăng ký:</strong> @Model.EnrollDate.ToString("dd/MM/yyyy")</p>
            </div>
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="EnrollmentId" />
            <input type="hidden" asp-for="StudentId" />
            <input type="hidden" asp-for="CourseId" />
            <input type="hidden" asp-for="EnrollDate" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Grade" class="form-label"></label>
                <input asp-for="Grade" type="number" step="0.01" class="form-control" />
                <span asp-validation-for="Grade" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">Lưu điểm</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}