@model SchoolApp.DTOs.EditProfileViewModel
@{
    ViewData["Title"] = "Sửa thông tin cá nhân";
    var pwdErrorsJson = TempData["PwdErrors"]?.ToString();
    var pwdErrors = pwdErrorsJson != null
        ? System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(pwdErrorsJson)
        : null;
}

@section Styles {
    <style>
        body {
            background: var(--navy-light) !important;
        }

        .sa-main {
            padding: 0 !important;
        }

            .sa-main > .container {
                max-width: 100% !important;
                padding: 0 !important;
                width: 100% !important;
            }
    </style>
}

<div style="
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100vh - 66px);
    background: var(--navy-light);
">
    <!-- ===== Left: Decorative Panel ===== -->
    <div style="
        background: linear-gradient(135deg, rgb(201,168,76) 0%, rgb(232,201,110) 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 2.5rem;
        position: relative;
        overflow: hidden;
    ">
        <!-- Decorative circles -->
        <div style="
            position:absolute; top:-100px; left:-100px;
            width:350px; height:350px;
            border-radius:50%;
            background: radial-gradient(circle, rgba(13,27,42,0.1) 0%, transparent 70%);
            pointer-events:none;
        "></div>
        <div style="
            position:absolute; bottom:-80px; right:-80px;
            width:280px; height:280px;
            border-radius:50%;
            background: radial-gradient(circle, rgba(13,27,42,0.07) 0%, transparent 70%);
            pointer-events:none;
        "></div>
        <div style="
            position:absolute; top:40%; left:-40px;
            width:180px; height:180px;
            border-radius:50%;
            border: 1px solid rgba(13,27,42,0.12);
            pointer-events:none;
        "></div>

        <!-- Avatar placeholder -->
        <div style="
            width: 90px; height: 90px;
            background: var(--navy-light);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 2.8rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 12px 32px rgba(13,27,42,0.25);
        ">
            👤
        </div>

        <h1 style="
            font-family: var(--font-display);
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: .5rem;
            text-align: center;
        ">
            Tài khoản của tôi
        </h1>

        <p style="
            color: rgba(13,27,42,0.65);
            font-size: .9rem;
            text-align: center;
            margin-bottom: 2.5rem;
            max-width: 270px;
            line-height: 1.7;
        ">Cập nhật thông tin cá nhân và bảo mật tài khoản của bạn.</p>

        <!-- Info cards -->
        <div style="display:flex; flex-direction:column; gap:.85rem; width:100%; max-width:270px;">
            <div style="
                background: rgba(13,27,42,0.08);
                border: 1px solid rgba(13,27,42,0.15);
                border-radius: 10px;
                padding: .85rem 1rem;
                display:flex; align-items:center; gap:.75rem;
            ">
                <i class="bi bi-person-badge-fill" style="color:var(--navy); font-size:1.1rem;"></i>
                <div>
                    <div style="color:var(--navy); font-size:.85rem; font-weight:600;">Thông tin cá nhân</div>
                    <div style="color:rgba(13,27,42,0.5); font-size:.78rem;">Tên, SĐT, ngày sinh, địa chỉ</div>
                </div>
            </div>
            <div style="
                background: rgba(13,27,42,0.08);
                border: 1px solid rgba(13,27,42,0.15);
                border-radius: 10px;
                padding: .85rem 1rem;
                display:flex; align-items:center; gap:.75rem;
            ">
                <i class="bi bi-shield-lock-fill" style="color:var(--navy); font-size:1.1rem;"></i>
                <div>
                    <div style="color:var(--navy); font-size:.85rem; font-weight:600;">Bảo mật</div>
                    <div style="color:rgba(13,27,42,0.5); font-size:.78rem;">Đổi mật khẩu an toàn</div>
                </div>
            </div>
        </div>

        <div style="
            width:100%; max-width:270px;
            height:1px;
            background: rgba(13,27,42,0.15);
            margin: 2rem 0 1.25rem;
        "></div>

        <p style="color:rgba(13,27,42,0.45); font-size:.78rem; text-align:center;">
            © 2026 SchoolApp · Học không giới hạn
        </p>
    </div>

    <!-- ===== Right: Form ===== -->
    <div style="
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 2.5rem 2rem;
        position: relative;
    ">
        <!-- Subtle bg decoration -->
        <div style="
            position:absolute; bottom:-60px; right:-60px;
            width:280px; height:280px;
            border-radius:50%;
            background: radial-gradient(circle, rgba(201,168,76,0.07) 0%, transparent 70%);
            pointer-events:none;
        "></div>

        <div class="sa-card" style="width:100%; max-width:480px; position:relative;">

            <!-- Header -->
            <div style="
                background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
                border-radius: 12px 12px 0 0;
                padding: 1.5rem 1.5rem 0;
                text-align: center;
            ">
                <h2 style="
                    font-family: var(--font-display);
                    font-size: 1.5rem;
                    font-weight: 700;
                    color: var(--navy);
                    margin-bottom: .2rem;
                ">
                    Chỉnh sửa tài khoản
                </h2>
                <p style="color: rgba(13,27,42,0.6); font-size:.85rem; margin-bottom: 1.25rem;">
                    Cập nhật thông tin cá nhân và mật khẩu
                </p>

                <!-- Tabs -->
                <div style="display: flex; gap: 0; margin-top: .5rem;">
                    <button type="button" id="tab-profile"
                            onclick="switchTab('profile')"
                            style="
                        flex: 1; border: none; cursor: pointer; padding: .65rem 1rem;
                        font-weight: 600; font-size: .88rem;
                        background: var(--navy-light); color: var(--gold);
                        border-radius: 8px 0 0 0;
                        transition: opacity .2s;
                    ">
                        <i class="bi bi-person-fill"></i> Thông tin
                    </button>
                    <button type="button" id="tab-password"
                            onclick="switchTab('password')"
                            style="
                        flex: 1; border: none; cursor: pointer; padding: .65rem 1rem;
                        font-weight: 600; font-size: .88rem;
                        background: rgba(13,27,42,0.12); color: rgba(13,27,42,0.65);
                        border-radius: 0 8px 0 0;
                        transition: opacity .2s;
                    ">
                        <i class="bi bi-shield-lock-fill"></i> Đổi mật khẩu
                    </button>
                </div>
            </div>

            <!-- Body -->
            <div class="sa-card-body">

                <!-- Panel: Thông tin cá nhân -->
                <div id="panel-profile">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        var generalErrors = ViewData.ModelState[""]?.Errors;
                        if (generalErrors != null && generalErrors.Count > 0)
                        {
                            <div class="sa-alert sa-alert-danger" style="margin-bottom:1rem;">
                                <span class="sa-alert-icon"><i class="bi bi-exclamation-circle-fill"></i></span>
                                <span>@generalErrors[0].ErrorMessage</span>
                            </div>
                        }
                    }

                    <form asp-action="EditProfile" method="post">
                        @Html.AntiForgeryToken()

                        <div class="sa-form-group">
                            <label class="sa-label" asp-for="FullName">
                                Họ và tên <span style="color:var(--danger)">*</span>
                            </label>
                            <input class="sa-input" asp-for="FullName"
                                   placeholder="Nguyễn Văn A"
                                   autocomplete="name" />
                            <span asp-validation-for="FullName"
                                  style="font-size:.78rem; color:var(--danger); margin-top:4px; display:block;"></span>
                        </div>

                        <div class="sa-form-group">
                            <label class="sa-label" asp-for="Phone">Số điện thoại</label>
                            <input class="sa-input" asp-for="Phone"
                                   type="tel" placeholder="0901234567"
                                   autocomplete="tel" />
                            <span asp-validation-for="Phone"
                                  style="font-size:.78rem; color:var(--danger); margin-top:4px; display:block;"></span>
                        </div>

                        <div class="sa-form-group">
                            <label class="sa-label" asp-for="DateOfBirth">Ngày sinh</label>
                            <input class="sa-input" asp-for="DateOfBirth"
                                   type="date" autocomplete="bday" />
                            <span asp-validation-for="DateOfBirth"
                                  style="font-size:.78rem; color:var(--danger); margin-top:4px; display:block;"></span>
                        </div>

                        <div class="sa-form-group" style="margin-bottom:1.5rem;">
                            <label class="sa-label" asp-for="Address">Địa chỉ</label>
                            <textarea class="sa-input" asp-for="Address"
                                      placeholder="123 Đường ABC, TP.Đà Nẵng"
                                      rows="2"
                                      style="resize:vertical;"></textarea>
                            <span asp-validation-for="Address"
                                  style="font-size:.78rem; color:var(--danger); margin-top:4px; display:block;"></span>
                        </div>

                        <button type="submit" class="sa-btn sa-btn-primary" style="width:100%; justify-content:center;">
                            <i class="bi bi-check-lg"></i> Lưu thay đổi
                        </button>
                    </form>
                </div>

                <!-- Panel: Đổi mật khẩu -->
                <div id="panel-password" style="display:none;">
                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()

                        <div class="sa-form-group">
                            <label class="sa-label" for="CurrentPassword">
                                Mật khẩu hiện tại <span style="color:var(--danger)">*</span>
                            </label>
                            <div style="position:relative;">
                                <input class="sa-input" type="password" id="CurrentPassword" name="CurrentPassword"
                                       placeholder="Nhập mật khẩu hiện tại"
                                       autocomplete="current-password"
                                       style="padding-right:46px;" />
                                <button type="button" onclick="togglePwd('CurrentPassword', this)"
                                        style="position:absolute;right:1px;top:1px;bottom:1px;width:42px;border:none;
                                           background:transparent;color:var(--text-light);cursor:pointer;
                                           display:flex;align-items:center;justify-content:center;
                                           border-radius:0 var(--radius-sm) var(--radius-sm) 0;">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            @if (pwdErrors != null && pwdErrors.ContainsKey("CurrentPassword"))
                            {
                                <span style="font-size:.78rem;color:var(--danger);margin-top:4px;display:block;">@pwdErrors["CurrentPassword"]</span>
                            }
                        </div>

                        <div class="sa-form-group">
                            <label class="sa-label" for="NewPassword">
                                Mật khẩu mới <span style="color:var(--danger)">*</span>
                            </label>
                            <div style="position:relative;">
                                <input class="sa-input" type="password" id="NewPassword" name="NewPassword"
                                       placeholder="Ít nhất 6 ký tự"
                                       autocomplete="new-password"
                                       style="padding-right:46px;" />
                                <button type="button" onclick="togglePwd('NewPassword', this)"
                                        style="position:absolute;right:1px;top:1px;bottom:1px;width:42px;border:none;
                                           background:transparent;color:var(--text-light);cursor:pointer;
                                           display:flex;align-items:center;justify-content:center;
                                           border-radius:0 var(--radius-sm) var(--radius-sm) 0;">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            @if (pwdErrors != null && pwdErrors.ContainsKey("NewPassword"))
                            {
                                <span style="font-size:.78rem;color:var(--danger);margin-top:4px;display:block;">@pwdErrors["NewPassword"]</span>
                            }
                        </div>

                        <div class="sa-form-group" style="margin-bottom:1.5rem;">
                            <label class="sa-label" for="ConfirmNewPassword">
                                Xác nhận mật khẩu mới <span style="color:var(--danger)">*</span>
                            </label>
                            <div style="position:relative;">
                                <input class="sa-input" type="password" id="ConfirmNewPassword" name="ConfirmNewPassword"
                                       placeholder="Nhập lại mật khẩu mới"
                                       autocomplete="new-password"
                                       style="padding-right:46px;" />
                                <button type="button" onclick="togglePwd('ConfirmNewPassword', this)"
                                        style="position:absolute;right:1px;top:1px;bottom:1px;width:42px;border:none;
                                           background:transparent;color:var(--text-light);cursor:pointer;
                                           display:flex;align-items:center;justify-content:center;
                                           border-radius:0 var(--radius-sm) var(--radius-sm) 0;">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            @if (pwdErrors != null && pwdErrors.ContainsKey("ConfirmNewPassword"))
                            {
                                <span style="font-size:.78rem;color:var(--danger);margin-top:4px;display:block;">@pwdErrors["ConfirmNewPassword"]</span>
                            }
                        </div>

                        <button type="submit" class="sa-btn sa-btn-primary" style="width:100%; justify-content:center;">
                            <i class="bi bi-shield-check"></i> Đổi mật khẩu
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function switchTab(tab) {
            var isProfile = tab === 'profile';
            document.getElementById('panel-profile').style.display = isProfile ? '' : 'none';
            document.getElementById('panel-password').style.display = isProfile ? 'none' : '';

            var tabProfile = document.getElementById('tab-profile');
            var tabPwd = document.getElementById('tab-password');

            tabProfile.style.background = isProfile ? 'var(--navy)' : 'rgba(13,27,42,0.12)';
            tabProfile.style.color = isProfile ? 'var(--gold)' : 'rgba(13,27,42,0.65)';
            tabPwd.style.background = isProfile ? 'rgba(13,27,42,0.12)' : 'var(--navy)';
            tabPwd.style.color = isProfile ? 'rgba(13,27,42,0.65)' : 'var(--gold)';
        }

        function togglePwd(inputId, btn) {
            var input = document.getElementById(inputId);
            var icon = btn.querySelector('i');
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            }
        }

        @if (TempData["ActiveTab"]?.ToString() == "password")
        {
                    <text>document.addEventListener('DOMContentLoaded', function() { switchTab('password'); });</text>
        }
    </script>
}