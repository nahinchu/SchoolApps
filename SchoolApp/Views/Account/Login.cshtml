@model SchoolApp.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

@section Styles {
    <style>
        body {
            background: var(--navy-light) !important;
        }

        .sa-main {
            padding: 0 !important;
        }

            .sa-main > .container {
                max-width: 100% !important;
                padding: 0 !important;
                width: 100% !important;
            }
    </style>
}

<div style="
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100vh - 66px);
    background: var(--navy-light);
">
    <!-- ===== Left: Decorative Panel ===== -->
    <div style="
        background: linear-gradient(135deg, rgb(201,168,76) 0%, rgb(232,201,110) 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 2.5rem;
        position: relative;
        overflow: hidden;
    ">
        <!-- Decorative circles -->
        <div style="
            position:absolute; top:-100px; left:-100px;
            width:350px; height:350px;
            border-radius:50%;
            background: radial-gradient(circle, rgba(13,27,42,0.1) 0%, transparent 70%);
            pointer-events:none;
        "></div>
        <div style="
            position:absolute; bottom:-80px; right:-80px;
            width:280px; height:280px;
            border-radius:50%;
            background: radial-gradient(circle, rgba(13,27,42,0.07) 0%, transparent 70%);
            pointer-events:none;
        "></div>
        <div style="
            position:absolute; top:40%; left:-40px;
            width:180px; height:180px;
            border-radius:50%;
            border: 1px solid rgba(13,27,42,0.12);
            pointer-events:none;
        "></div>

        <!-- Logo + Brand -->
        <div style="
            width: 80px; height: 80px;
            background: var(--navy-light);
            border-radius: 20px;
            display: flex; align-items: center; justify-content: center;
            font-size: 2.5rem;
            margin-bottom: 1.5rem;
            box-shadow: 0 12px 32px rgba(13,27,42,0.25);
        ">
            🎓
        </div>

        <h1 style="
            font-family: var(--font-display);
            font-size: 2rem;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: .5rem;
            text-align: center;
        ">
            SchoolApp
        </h1>

        <p style="
            color: rgba(13,27,42,0.65);
            font-size: .95rem;
            text-align: center;
            margin-bottom: 2.5rem;
            max-width: 280px;
            line-height: 1.7;
        ">Nền tảng học tập trực tuyến hiện đại — học mọi lúc, mọi nơi.</p>

        <!-- Feature list -->
        <div style="display:flex; flex-direction:column; gap:.85rem; width:100%; max-width:280px;">
            <div style="display:flex; align-items:center; gap:.75rem;">
                <div style="
                    width:32px; height:32px; border-radius:8px; flex-shrink:0;
                    background: rgba(13,27,42,0.12);
                    display:flex; align-items:center; justify-content:center;
                    color:var(--navy); font-size:.9rem;
                ">
                    <i class="bi bi-play-circle-fill"></i>
                </div>
                <span style="color:rgba(13,27,42,0.8); font-size:.88rem;">Khoá học video chất lượng cao</span>
            </div>
            <div style="display:flex; align-items:center; gap:.75rem;">
                <div style="
                    width:32px; height:32px; border-radius:8px; flex-shrink:0;
                    background: rgba(13,27,42,0.12);
                    display:flex; align-items:center; justify-content:center;
                    color:var(--navy); font-size:.9rem;
                ">
                    <i class="bi bi-patch-check-fill"></i>
                </div>
                <span style="color:rgba(13,27,42,0.8); font-size:.88rem;">Bài kiểm tra & chứng chỉ</span>
            </div>
            <div style="display:flex; align-items:center; gap:.75rem;">
                <div style="
                    width:32px; height:32px; border-radius:8px; flex-shrink:0;
                    background: rgba(13,27,42,0.12);
                    display:flex; align-items:center; justify-content:center;
                    color:var(--navy); font-size:.9rem;
                ">
                    <i class="bi bi-people-fill"></i>
                </div>
                <span style="color:rgba(13,27,42,0.8); font-size:.88rem;">Cộng đồng học viên năng động</span>
            </div>
        </div>

        <!-- Divider line -->
        <div style="
            width:100%; max-width:280px;
            height:1px;
            background: rgba(13,27,42,0.15);
            margin: 2rem 0 1.25rem;
        "></div>

        <p style="color:rgba(13,27,42,0.45); font-size:.78rem; text-align:center;">
            © 2026 SchoolApp · Học không giới hạn
        </p>
    </div>

    <!-- ===== Right: Form ===== -->
    <div style="
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2.5rem 2rem;
        position: relative;
    ">
        <!-- Subtle bg decoration -->
        <div style="
            position:absolute; bottom:-60px; right:-60px;
            width:280px; height:280px;
            border-radius:50%;
            background: radial-gradient(circle, rgba(201,168,76,0.07) 0%, transparent 70%);
            pointer-events:none;
        "></div>

        <!-- Card -->
        <div class="sa-card" style="width:100%; max-width:400px; position:relative;">

            <!-- Header -->
            <div style="
                background: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
                border-radius: 12px 12px 0 0;
                padding: 1.75rem 1.5rem 1.5rem;
                text-align: center;
            ">
                <h2 style="
                    font-family: var(--font-display);
                    font-size: 1.5rem;
                    font-weight: 700;
                    color: var(--navy);
                    margin-bottom: .2rem;
                ">
                    Đăng nhập
                </h2>
                <p style="color: rgba(13,27,42,0.6); font-size:.85rem;">
                    Chào mừng trở lại SchoolApp
                </p>
            </div>

            <!-- Body -->
            <div class="sa-card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="sa-alert sa-alert-danger" style="margin-bottom:1rem;">
                        <span class="sa-alert-icon"><i class="bi bi-exclamation-circle-fill"></i></span>
                        <span>Sai email hoặc mật khẩu.</span>
                    </div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()

                    <div class="sa-form-group">
                        <label class="sa-label" asp-for="Email">
                            Email <span style="color:var(--danger)">*</span>
                        </label>
                        <input class="sa-input" asp-for="Email"
                               type="email" placeholder="example@email.com"
                               autocomplete="email" />
                        <span asp-validation-for="Email"
                              style="font-size:.78rem; color:var(--danger); margin-top:4px; display:block;"></span>
                    </div>

                    <div class="sa-form-group" style="margin-bottom:1.5rem;">
                        <label class="sa-label" asp-for="Password">
                            Mật khẩu <span style="color:var(--danger)">*</span>
                        </label>
                        <input class="sa-input" asp-for="Password"
                               type="password" placeholder="Nhập mật khẩu..."
                               autocomplete="current-password" />
                        <span asp-validation-for="Password"
                              style="font-size:.78rem; color:var(--danger); margin-top:4px; display:block;"></span>
                    </div>

                    <button type="submit" class="sa-btn sa-btn-primary" style="width:100%; justify-content:center;">
                        <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                    </button>
                </form>

                <p style="text-align:center; margin-top:1.25rem; font-size:.82rem; color:var(--text-light);">
                    Chưa có tài khoản?
                    <a asp-controller="Account" asp-action="Register"
                       style="color:var(--gold); font-weight:600;">Đăng ký ngay</a>
                </p>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}