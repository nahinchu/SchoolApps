@model SchoolApp.Models.Payment
@{
    ViewData["Title"] = "Thanh toán thành công";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-sm border-0 p-4">
                <div class="mb-3">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                </div>
                <h4 class="fw-bold mb-1">Thanh toán thành công!</h4>
                <p class="text-muted mb-4">Bạn đã đăng ký khóa học thành công.</p>

                <div class="text-start bg-light rounded p-3 mb-4">
                    <div class="row mb-2">
                        <div class="col-5 text-muted">Khóa học</div>
                        <div class="col-7 fw-semibold">@Model.Course?.CourseName</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-5 text-muted">Số tiền</div>
                        <div class="col-7 fw-semibold" style="color: var(--sa-gold, #c9a84c);">
                            @Model.Amount.ToString("N0") VNĐ
                        </div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-5 text-muted">Mã giao dịch</div>
                        <div class="col-7 text-monospace small">#@Model.OrderCode</div>
                    </div>
                    <div class="row">
                        <div class="col-5 text-muted">Thời gian</div>
                        <div class="col-7 small">@Model.PaidAt?.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                </div>

                <a asp-controller="Enrollment" asp-action="MyEnrollments"
                   class="btn btn-primary w-100 py-2"
                   style="background: var(--sa-navy, #1a2f5a); border:none;">
                    <i class="bi bi-journal-text me-2"></i>Xem khóa học của tôi
                </a>
            </div>
        </div>
    </div>
</div>
