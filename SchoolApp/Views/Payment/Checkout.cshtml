@model SchoolApp.Models.Course
@{
    ViewData["Title"] = "Xác nhận thanh toán";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header py-3" style="background: var(--sa-navy, #1a2f5a); color:#fff;">
                    <h5 class="mb-0"><i class="bi bi-credit-card me-2"></i>Xác nhận đăng ký & thanh toán</h5>
                </div>
                <div class="card-body p-4">
                    <h6 class="text-muted mb-1">Khóa học</h6>
                    <p class="fw-semibold fs-5 mb-3">@Model.CourseName</p>

                    @if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        <p class="text-muted small mb-3">@Model.Description</p>
                    }

                    <hr />

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="text-muted">Học phí</span>
                        <span class="fw-bold fs-4" style="color: var(--sa-gold, #c9a84c);">
                            @Model.Fee.ToString("N0") VNĐ
                        </span>
                    </div>

                    <div id="error-msg" class="alert alert-danger d-none"></div>

                    <form id="payment-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="courseId" value="@Model.CourseId" />
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" id="pay-btn"
                                style="background: var(--sa-navy, #1a2f5a); border:none;">
                            <i class="bi bi-shield-lock me-2"></i>Thanh toán qua PayOS
                        </button>
                    </form>

                    <a asp-controller="Course" asp-action="Index" class="btn btn-link w-100 mt-2 text-muted">
                        Hủy, quay lại
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('payment-form').addEventListener('submit', async function (e) {
            e.preventDefault();
            const btn = document.getElementById('pay-btn');
            const errDiv = document.getElementById('error-msg');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';
            errDiv.classList.add('d-none');

            const formData = new FormData(this);
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            try {
                const res = await fetch('/Payment/CreatePaymentLink', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    body: formData
                });
                const data = await res.json();
                if (data.success) {
                    window.location.href = data.checkoutUrl;
                } else {
                    errDiv.textContent = data.message || 'Có lỗi xảy ra';
                    errDiv.classList.remove('d-none');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-shield-lock me-2"></i>Thanh toán qua PayOS';
                }
            } catch {
                errDiv.textContent = 'Không thể kết nối. Vui lòng thử lại.';
                errDiv.classList.remove('d-none');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-shield-lock me-2"></i>Thanh toán qua PayOS';
            }
        });
    </script>
}