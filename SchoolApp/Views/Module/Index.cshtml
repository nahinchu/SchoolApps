@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<SchoolApp.Models.Module>

@{
    ViewData["Title"] = "Quản lý Chương";
    var courseId = ViewData["CourseId"] != null ? (int)ViewData["CourseId"] : 0;
    var courseName = ViewData["CourseName"] as string ?? "Khóa học";
}

<div class="sa-page-hero">
    <h1>📖 Quản lý Chương - <span style="color:var(--gold);">@courseName</span></h1>
    <p>Quản lý cấu trúc chương học trong khóa</p>
</div>

<!-- TOOLBAR -->
<div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; margin-bottom:1.5rem; flex-wrap:wrap;">
    <a asp-controller="Course" asp-action="Index" class="btn btn-outline-secondary">
        ← Danh sách khóa học
    </a>

    <form id="searchForm" method="get" style="flex:1; max-width:420px; display:flex; gap:0;">
        <input type="hidden" name="courseId" value="@courseId" />
        <div style="position:relative; flex:1;">
            <i class="bi bi-search" style="position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--text-light);"></i>
            <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]"
                   class="sa-input" placeholder="Tìm chương..."
                   style="padding-left:42px; border-radius:var(--radius-sm) 0 0 var(--radius-sm);" />
        </div>
        <button type="submit" class="sa-btn sa-btn-primary"
                style="border-radius:0 var(--radius-sm) var(--radius-sm) 0; padding:10px 20px;">
            <i class="bi bi-search"></i>
        </button>
    </form>

    <button type="button" class="sa-btn sa-btn-gold" data-bs-toggle="modal" data-bs-target="#moduleModal"
            onclick="openCreateModal()">
        <i class="bi bi-plus-circle me-2"></i> Thêm chương mới
    </button>
</div>

<div id="moduleTableContainer">
    @{
        ViewData["CourseId"] = courseId;
    }
    @await Html.PartialAsync("_ModuleTable", Model)
</div>

<!-- ==================== MODAL CREATE / EDIT ==================== -->
<div class="modal fade" id="moduleModal" tabindex="-1" aria-labelledby="moduleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border:none; border-radius:var(--radius-md); overflow:hidden; box-shadow:var(--shadow-lg);">
            <div class="modal-header" style="background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%); padding:1.25rem 1.5rem; border:none;">
                <h5 id="moduleModalLabel" style="font-family:var(--font-display); font-size:1.15rem; font-weight:600; color:var(--gold-light); margin:0;">
                    Thêm chương mới
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>

            <div class="modal-body" style="padding:1.5rem; background:var(--white);">
                <div id="modalResult"></div>
                <form id="moduleForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="ModuleId" name="ModuleId" value="0" />
                    <input type="hidden" id="CourseId" name="CourseId" value="@courseId" />

                    <div class="row">
                        <div class="col-md-8">
                            <div class="sa-form-group">
                                <label class="sa-label" for="Title">Tên chương <span style="color:var(--danger)">*</span></label>
                                <input type="text" id="Title" name="Title" class="sa-input" placeholder="Nhập tên chương" />
                                <div class="invalid-feedback" id="err-Title"></div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="sa-form-group">
                                <label class="sa-label" for="OrderIndex">Thứ tự</label>
                                <input type="number" id="OrderIndex" name="OrderIndex" class="sa-input" min="0" value="0" />
                                <div class="invalid-feedback" id="err-OrderIndex"></div>
                            </div>
                        </div>
                    </div>

                    <div class="sa-form-group">
                        <label class="sa-label" for="Description">Mô tả</label>
                        <textarea id="Description" name="Description" class="sa-input" rows="4"
                                  placeholder="Mô tả ngắn gọn về chương..."></textarea>
                        <div class="invalid-feedback" id="err-Description"></div>
                    </div>

                    <div class="form-check form-switch">
                        <input type="checkbox" id="IsPublished" name="IsPublished" value="true" class="form-check-input" checked />
                        <label for="IsPublished" class="form-check-label">Công bố chương này (học viên có thể thấy)</label>
                    </div>
                </form>
            </div>

            <div class="modal-footer" style="padding:1rem 1.5rem; background:var(--off-white); border-top:1px solid var(--smoke);">
                <button type="button" class="sa-btn sa-btn-outline" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="sa-btn sa-btn-primary" id="btnSaveModule">
                    <i class="bi bi-check-lg"></i> <span class="btn-text">Lưu</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <form id="antiForgeryForm">@Html.AntiForgeryToken()</form>

    <script>
        var isEditMode = false;
        var currentCourseId = @courseId;

        function clearErrors() {
            $('#modalResult').html('');
            $('#moduleForm .sa-input').removeClass('is-invalid');
            $('#moduleForm [id^="err-"]').text('');
        }

        function openCreateModal() {
            isEditMode = false;
            $('#moduleModalLabel').text('➕ Thêm chương mới');
            $('#btnSaveModule .btn-text').text('Lưu');
            $('#moduleForm')[0].reset();
            $('#ModuleId').val(0);
            $('#CourseId').val(currentCourseId);
            $('#IsPublished').prop('checked', true);
            clearErrors();
        }

        function openEditModal(id) {
            isEditMode = true;
            $('#moduleModalLabel').text('✏️ Sửa chương');
            $('#btnSaveModule .btn-text').text('Cập nhật');
            clearErrors();

            $.get('@Url.Action("GetModule", "Module")/' + id, function (data) {
                $('#ModuleId').val(data.moduleId);
                $('#Title').val(data.title);
                $('#Description').val(data.description);
                $('#OrderIndex').val(data.orderIndex);
                $('#IsPublished').prop('checked', data.isPublished);
                $('#CourseId').val(data.courseId);
                $('#moduleModal').modal('show');
            }).fail(function () {
                showToast('Không thể tải thông tin chương!', 'danger');
            });
        }

        $(function () {
            // Lưu Module (Create & Edit)
            $('#btnSaveModule').on('click', function () {
                clearErrors();
                var url = isEditMode
                    ? '@Url.Action("EditAjax", "Module")'
                    : '@Url.Action("CreateAjax", "Module")';

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: $('#moduleForm').serialize(),
                    success: function (res) {
                        if (res.success) {
                            $('#moduleModal').modal('hide');
                            showToast(res.message, 'success');
                            loadModules(1);
                        } else if (res.errors) {
                            $.each(res.errors, function (field, messages) {
                                $('#' + field).addClass('is-invalid');
                                $('#err-' + field).text(messages.join(', '));
                            });
                        } else {
                            $('#modalResult').html(
                                '<div class="sa-alert sa-alert-danger"><i class="bi bi-exclamation-circle-fill"></i> ' +
                                $('<span>').text(res.message).html() + '</div>'
                            );
                        }
                    },
                    error: function (xhr) {
                        showToast('Lỗi: ' + (xhr.status === 403 ? 'Bạn không có quyền Admin!' : xhr.statusText), 'danger');
                    }
                });
            });

            // Tìm kiếm
            $('#searchForm').on('submit', function (e) {
                e.preventDefault();
                loadModules(1);
            });

            // Phân trang AJAX
            $(document).on('click', '.ajax-page-link', function (e) {
                e.preventDefault();
                var match = $(this).attr('href').match(/page=(\d+)/);
                loadModules(match ? parseInt(match[1]) : 1);
            });

            // Xóa Module
            $(document).on('click', '.btn-delete-module', function () {
                if (!confirm('Bạn có chắc muốn xóa chương này? Tất cả bài học bên trong cũng sẽ bị xóa.')) return;

                var id = $(this).data('id');
                var token = $('#antiForgeryForm input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("Delete", "Module")',
                    type: 'POST',
                    data: { id: id, __RequestVerificationToken: token },
                    success: function (res) {
                        if (res.success) {
                            showToast(res.message, 'success');
                            loadModules(1);
                        } else {
                            showToast(res.message, 'danger');
                        }
                    },
                    error: function () {
                        showToast('Có lỗi xảy ra khi xóa!', 'danger');
                    }
                });
            });

            // Hàm load bảng
            window.loadModules = function(page) {
                var searchTerm = $('#searchForm input[name="searchTerm"]').val();
                $.ajax({
                    url: '@Url.Action("Index", "Module")',
                    type: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    data: {
                        courseId: currentCourseId,
                        searchTerm: searchTerm,
                        page: page
                    },
                    success: function (html) {
                        $('#moduleTableContainer').html(html);
                    }
                });
            };

            // Toast notification
            window.showToast = function (message, type) {
                var cls = type === 'success' ? 'sa-alert-success' : 'sa-alert-danger';
                var icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-circle-fill';
                var toast = $(`
                    <div class="sa-alert ${cls}" style="position:fixed; top:1rem; right:1rem; z-index:9999; min-width:320px; box-shadow:var(--shadow-md);">
                        <span class="sa-alert-icon"><i class="bi ${icon}"></i></span>
                        <span>${message}</span>
                        <button class="sa-alert-close" onclick="$(this).parent().remove()"><i class="bi bi-x"></i></button>
                    </div>`);
                $('body').append(toast);
                setTimeout(() => toast.fadeOut(300, () => toast.remove()), 3000);
            };
        });
    </script>
}